    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم الوصول إلى الكاميرا لتسجيل فيديو دليل مع تراكب الديسيبل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required to record evidence video with decibel overlays."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita la cámara para grabar vídeo de prueba con superposición de decibelios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès à la caméra est requis pour enregistrer une preuve vidéo avec mesures en décibels."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डेसिबल ओवरले के साथ साक्ष्य वीडियो के लिए कैमरा एक्सेस आवश्यक है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "É necessário acesso à câmera para gravar vídeo de prova com sobreposição de decibéis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нужен доступ к камере для записи видеодоказательств с наложением децибел."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要相机权限以录制带分贝叠加的取证视频。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要相機權限以錄製帶分貝疊加的取證影片。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Необходим е достъп до камерата за запис на доказателствено видео с децибелни наслагвания."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Cal accedir a la càmera per gravar un vídeo de proves amb superposicions de decibels."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "K záznamu důkazního videa s decibelovými překryvy je vyžadován přístup ke kameře."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameraadgang er påkrævet for at optage bevisvideo med decibeloverlejringer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für die Aufnahme von Beweisvideos mit Dezibel-Overlays ist Kamerazugriff erforderlich."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απαιτείται πρόσβαση στην κάμερα για την εγγραφή βίντεο αποδεικτικών στοιχείων με επικαλύψεις ντεσιμπέλ."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameran pääsy vaaditaan todistevideon tallentamiseen desibelipeittokuvalla."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נדרשת גישה למצלמה כדי להקליט וידאו ראיות עם שכבות על דציבלים."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Potreban je pristup kameri za snimanje video dokaza s slojevima decibela."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera-hozzáférés szükséges ahhoz, hogy bizonyítékokat tartalmazó videót rögzíthessen decibel lefedéssel."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera diperlukan untuk merekam video bukti dengan hamparan desibel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per registrare video di prova con sovrapposizioni di decibel è necessario l'accesso alla telecamera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デシベルオーバーレイを使用して証拠ビデオを録画するには、カメラへのアクセスが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데시벨 오버레이로 증거 영상을 녹화하려면 카메라 액세스가 필요합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera diperlukan untuk merakam video bukti dengan tindanan desibel."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameratilgang er nødvendig for å ta opp bevisvideo med desibeloverlegg."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cameratoegang is vereist om bewijsvideo met decibel-overlays op te nemen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby nagrać materiał dowodowy z nakładkami w decybelach, wymagany jest dostęp do kamery."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesul la cameră este necesar pentru a înregistra dovezi video cu suprapuneri în decibeli."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Na nahrávanie dôkazového videa s prekrytím decibelov je potrebný prístup k fotoaparátu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameraåtkomst krävs för att spela in bevisvideo med decibelöverlagringar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จำเป็นต้องเข้าถึงกล้องเพื่อบันทึกวิดีโอหลักฐานที่มีการซ้อนทับเดซิเบล"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Desibel katmanlarıyla kanıt videosu kaydetmek için kamera erişimi gereklidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ до камери потрібен для запису відео доказів із накладанням децибел."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần có quyền truy cập vào máy ảnh để ghi lại video bằng chứng với lớp phủ decibel."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُستخدم الموقع لتضمين إحداثيات GPS في فيديو الدليل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is used to embed GPS coordinates in evidence video."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicación se usa para incrustar coordenadas GPS en el vídeo de prueba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La position sert à intégrer les coordonnées GPS dans la preuve vidéo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साक्ष्य वीडियो में GPS निर्देशांक जोड़ने के लिए स्थान का उपयोग होता है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A localização é usada para incorporar coordenadas GPS no vídeo de prova."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Геопозиция используется для встраивания GPS-координат в видеодоказательство."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用位置信息将 GPS 坐标嵌入取证视频。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用位置資訊將 GPS 座標嵌入取證影片。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Местоположението се използва за вграждане на координати на GPS във видеоклип с доказателства."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicació s'utilitza per incrustar les coordenades GPS al vídeo de proves."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Poloha se používá k vložení souřadnic GPS do důkazního videa."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Placering bruges til at indlejre GPS koordinater i bevisvideo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Standort wird zum Einbetten von GPS-Koordinaten in Beweisvideos verwendet."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η τοποθεσία χρησιμοποιείται για την ενσωμάτωση συντεταγμένων GPS σε αποδεικτικό βίντεο."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sijaintia käytetään upottamaan GPS koordinaatit todistevideoon."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המיקום משמש להטמעת קואורדינטות GPS בסרטון ראיות."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokacija se koristi za ugrađivanje koordinata GPS u video dokaz."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hely a GPS koordináták bizonyítékvideóba ágyazására szolgál."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi digunakan untuk menyematkan koordinat GPS dalam video bukti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La posizione viene utilizzata per incorporare le coordinate GPS nel video delle prove."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報は、GPS 座標を証拠ビデオに埋め込むために使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위치는 증거 영상에 GPS 좌표를 삽입하는 데 사용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi digunakan untuk membenamkan koordinat GPS dalam video bukti."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Plassering brukes til å bygge inn GPS-koordinater i bevisvideo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatie wordt gebruikt om GPS coördinaten in bewijsvideo in te sluiten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokalizacja służy do umieszczania współrzędnych GPS w materiale wideo dowodowym."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Locația este folosită pentru a încorpora coordonatele GPS în videoclipul cu dovezi."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Poloha sa používa na vloženie súradníc GPS do dôkazového videa."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Plats används för att bädda in GPS-koordinater i bevisvideo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตำแหน่งใช้เพื่อฝังพิกัด GPS ในวิดีโอหลักฐาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konum, GPS koordinatlarını kanıt videosuna yerleştirmek için kullanılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Розташування використовується для вбудовування координат GPS у відео доказів."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
