        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este identificador é usado para exibir anúncios personalizados e medir o desempenho dos anúncios."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот идентификатор используется для показа персонализированной рекламы и оценки её эффективности."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此标识符用于投放个性化广告并衡量广告效果。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此識別碼用於投放個人化廣告並衡量廣告成效。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Този идентификатор се използва за предоставяне на персонализирани реклами и измерване на ефективността на рекламите."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquest identificador s'utilitza per oferir anuncis personalitzats i mesurar el rendiment dels anuncis."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento identifikátor se používá k zobrazování personalizovaných reklam a měření výkonu reklam."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne identifikator bruges til at levere tilpassede annoncer og måle annonceeffektivitet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Kennung wird verwendet, um personalisierte Anzeigen auszuliefern und die Anzeigenleistung zu messen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό το αναγνωριστικό χρησιμοποιείται για την προβολή εξατομικευμένων διαφημίσεων και τη μέτρηση της απόδοσης της διαφήμισης."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tätä tunnistetta käytetään räätälöityjen mainosten näyttämiseen ja mainosten tehokkuuden mittaamiseen."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
