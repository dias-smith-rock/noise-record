          "stringUnit": {
            "state": "translated",
            "value": "Цей ідентифікатор використовується для надання персоналізованої реклами та вимірювання ефективності реклами."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giá trị nhận dạng này dùng để phân phối quảng cáo được cá nhân hóa và đo lường hiệu suất quảng cáo."
          }
        }
      }
    }
  },
  "version": "1.0"
}
