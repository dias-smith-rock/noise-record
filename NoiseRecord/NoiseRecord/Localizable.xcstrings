    "silenceGrade.a.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بيئة هادئة جدًا مناسبة للراحة والتركيز."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Много тиха среда, подходяща за почивка и концентрация."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Entorn molt tranquil i adequat per al descans i la concentració."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Velmi klidné prostředí vhodné k odpočinku a soustředění."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Meget roligt miljø velegnet til hvile og koncentration."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sehr ruhige Umgebung, geeignet für Ruhe und Konzentration."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πολύ ήσυχο περιβάλλον κατάλληλο για ξεκούραση και συγκέντρωση."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Very quiet environment suitable for rest and concentration."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entorno muy silencioso, adecuado para descanso y concentración."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Erittäin hiljainen ympäristö, joka sopii lepoon ja keskittymiseen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Environnement très calme, propice au repos et à la concentration."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "סביבה שקטה מאוד המתאימה למנוחה וריכוז."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बहुत शांत वातावरण, आराम और एकाग्रता के लिए उपयुक्त।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vrlo mirno okruženje pogodno za odmor i koncentraciju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagyon csendes környezet, pihenésre és koncentrációra alkalmas."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lingkungan yang sangat tenang cocok untuk istirahat dan konsentrasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambiente molto tranquillo adatto al riposo e alla concentrazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "とても静かな環境で、休息や集中に最適です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "휴식과 집중에 적합한 매우 조용한 환경입니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Persekitaran yang sangat tenang sesuai untuk berehat dan tumpuan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Veldig rolig miljø egnet for hvile og konsentrasjon."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeer rustige omgeving geschikt voor rust en concentratie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bardzo ciche otoczenie, odpowiednie do odpoczynku i koncentracji."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambiente muito silencioso, adequado para descanso e concentração."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediu foarte linistit potrivit pentru odihna si concentrare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очень тихая среда, подходит для отдыха и концентрации."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Veľmi tiché prostredie vhodné na oddych a sústredenie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mycket tyst miljö som lämpar sig för vila och koncentration."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สภาพแวดล้อมที่เงียบสงบมากเหมาะสำหรับการพักผ่อนและมีสมาธิ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dinlenmeye ve konsantrasyona uygun çok sessiz bir ortam."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дуже тихе середовище, придатне для відпочинку та концентрації."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Môi trường rất yên tĩnh thích hợp để nghỉ ngơi và tập trung."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "非常安静，适合休息与专注。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "非常安靜，適合休息與專注。"
          }
        }
      }
    },
