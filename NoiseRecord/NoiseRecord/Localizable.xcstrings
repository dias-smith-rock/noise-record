    "modeSwitch.infoSheet.highSensitivity.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bypasses default iOS noise suppression filters to capture raw physical sound pressure. Readings are often higher than standard mode—this is normal. It is specifically engineered to detect low-frequency hums (e.g., AC units, transformers, structural building resonance) that you may barely hear but are physically present."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "绕过 iOS 默认降噪滤波，采集原始物理声压。读数常高于标准模式——这属正常现象。专为捕捉低频嗡鸣（如空调、变压器、建筑结构共振）而设计，这些声音您可能几乎听不到，但物理上确实存在。"
          }
        }
      }
    },
