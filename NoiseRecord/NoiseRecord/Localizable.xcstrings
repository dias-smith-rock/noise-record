          "stringUnit": {
            "state": "translated",
            "value": "Egyszeri vásárlás. Véglegesen eltávolítja az alkalmazásmegnyitási és közbeiktatott hirdetéseket ehhez az Apple ID-hez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembelian satu kali. Menghapus iklan pembuka aplikasi dan iklan interstisial untuk ID Apple ini secara permanen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Acquisto una tantum. Rimuove definitivamente gli annunci di apertura app e interstitial per questo ID Apple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1回限りの購入。この Apple ID のアプリ起動時の広告とインタースティシャル広告を完全に削除します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일회성 구매. 이 Apple ID에 대한 앱 오프닝 광고와 전면 광고를 영구적으로 제거합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Belian sekali. Mengalih keluar iklan terbuka dan iklan interstisial apl untuk ID Apple ini secara kekal."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Engangskjøp. Fjerner app åpne og mellomliggende annonser for denne Apple-ID-en permanent."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eenmalige aankoop. Verwijdert permanent app-open- en interstitial-advertenties voor deze Apple ID."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednorazowy zakup. Trwale usuwa reklamy otwierające aplikację i reklamy pełnoekranowe dla tego Apple ID."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "One-time purchase. Permanently removes app open and interstitial ads for this Apple ID."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Achiziție unică. Elimină definitiv anunțurile deschise pentru aplicații și anunțurile interstițiale pentru acest ID Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "One-time purchase. Permanently removes app open and interstitial ads for this Apple ID."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednorazový nákup. Natrvalo odstráni reklamy pri spustení aplikácie a intersticiálne reklamy pre toto Apple ID."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Engångsköp. Tar permanent bort appöppna annonser och mellansidesannonser för detta Apple-ID."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ซื้อครั้งเดียว. ลบโฆษณาเปิดแอปและโฆษณาคั่นระหว่างหน้าสำหรับ Apple ID นี้อย่างถาวร"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir kerelik satın alma. Bu Apple Kimliğine ilişkin uygulama açılış reklamlarını ve geçiş reklamlarını kalıcı olarak kaldırır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Одноразова покупка. Назавжди видаляє рекламу під час відкриття програми та проміжну рекламу для цього Apple ID."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mua một lần. Xóa vĩnh viễn quảng cáo khi mở ứng dụng và quảng cáo xen kẽ cho ID Apple này."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性买断，永久移除本 Apple ID 下的开屏与插屏广告。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性買斷，永久移除本 Apple ID 下的開屏與插屏廣告。"
          }
        }
      }
    },
