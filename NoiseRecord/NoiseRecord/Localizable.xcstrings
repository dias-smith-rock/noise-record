    "settings.calibration.footer": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خط الأساس لإزاحة الوضع 115–118 dB؛ يجب أن تقرأ غرفة هادئة نحو 30–40 dB. اضبط بمقياس احترافي عند الحاجة."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Базовата линия на отместването на режима е 115–118 dB; тиха стая трябва да бъде около 30–40 dB. Направете фина настройка с професионален измервателен уред, ако е необходимо."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La línia base de compensació del mode és 115–118 dB; una habitació tranquil·la hauria de llegir uns 30–40 dB. Ajusteu amb un mesurador professional si cal."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Základní offset režimu je 115–118 dB; v tiché místnosti by se mělo číst asi 30–40 dB. V případě potřeby dolaďte profesionálním měřičem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode offset baseline er 115–118 dB; et stille rum bør læse omkring 30–40 dB. Finjuster med en professionel måler, hvis det er nødvendigt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Grundlinie des Modusversatzes beträgt 115–118 dB; Ein ruhiger Raum sollte etwa 30–40 dB anzeigen. Nehmen Sie bei Bedarf eine Feinabstimmung mit einem professionellen Messgerät vor."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η βασική μετατόπιση λειτουργίας είναι 115–118 dB. ένα ήσυχο δωμάτιο θα πρέπει να διαβάζει περίπου 30–40 dB. Βελτιστοποιήστε με επαγγελματικό μετρητή εάν χρειάζεται."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode offset baseline is 115–118 dB; a quiet room should read about 30–40 dB. Fine-tune with a professional meter if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La línea base de offset del modo es 115–118 dB; una habitación tranquila debería marcar unos 30–40 dB. Ajusta con un sonómetro profesional si hace falta."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilasiirtymän perusviiva on 115–118 dB; hiljaisessa huoneessa pitäisi lukea noin 30–40 dB. Hienosäädä tarvittaessa ammattimittarilla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La base d’offset du mode est de 115–118 dB ; une pièce calme devrait afficher environ 30–40 dB. Ajustez avec un sonomètre pro si besoin."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קו הבסיס של היסט מצב הוא 115–118 dB; חדר שקט צריך לקרוא בערך 30-40 dB. כוונן עם מד מקצועי במידת הצורך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मोड ऑफ़सेट बेसलाइन 115–118 dB है; शांत कमरे में लगभग 30–40 dB दिखना चाहिए। ज़रूरत हो तो प्रो मीटर से फाइन-ट्यून करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Osnovna linija pomaka načina je 115–118 dB; mirna soba trebala bi iznositi oko 30–40 dB. Ako je potrebno, fino podesite s profesionalnim mjeračem."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A módeltolás alapvonala 115–118 dB; egy csendes szobában körülbelül 30–40 dB olvasható. Szükség esetén finomhangoljon professzionális mérőműszerrel."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Garis dasar mode offset adalah 115–118 dB; ruangan yang tenang seharusnya membaca sekitar 30–40 dB. Sempurnakan dengan meteran profesional jika diperlukan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La linea di base dell'offset della modalità è 115–118 dB; una stanza tranquilla dovrebbe leggere circa 30–40 dB. Se necessario, perfezionare la regolazione con un misuratore professionale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モード オフセット ベースラインは 115 ～ 118 dB です。静かな部屋では、およそ 30 ～ 40 dB と読む必要があります。必要に応じて専門のメーターを使用して微調整してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모드 오프셋 기준선은 115–118 dB입니다. 조용한 방은 30-40 dB 정도 되어야 합니다. 필요한 경우 전문 측정기를 사용하여 미세 조정하십시오."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Garis dasar mengimbangi mod ialah 115–118 dB; bilik yang sunyi hendaklah dibaca kira-kira 30–40 dB. Penalaan halus dengan meter profesional jika perlu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode offset baseline er 115–118 dB; et stille rom bør lese ca 30–40 dB. Finjuster med en profesjonell måler om nødvendig."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Basislijn modus-offset is 115–118 dB; een rustige kamer zou ongeveer 30–40 dB moeten zijn. Fijnafstemming met een professionele meter indien nodig."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Linia bazowa przesunięcia trybu wynosi 115–118 dB; cichy pokój powinien czytać około 30–40 dB. W razie potrzeby dostrój za pomocą profesjonalnego miernika."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A linha de base de offset do modo é 115–118 dB; um ambiente silencioso deve marcar cerca de 30–40 dB. Ajuste com um medidor profissional se necessário."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Linia de bază pentru compensarea modului este 115–118 dB; o cameră liniștită ar trebui să citească aproximativ 30–40 dB. Ajustați cu un contor profesional dacă este necesar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Базовое смещение режима 115–118 dB; в тихой комнате должно быть около 30–40 dB. При необходимости подстройте профессиональным шумомером."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Základná línia posunu režimu je 115–118 dB; tichá miestnosť by mala mať hodnotu 30–40 dB. V prípade potreby dolaďte profesionálnym meračom."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägesoffsetbaslinjen är 115–118 dB; ett tyst rum bör läsa ca 30–40 dB. Finjustera med en professionell mätare om det behövs."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โหมดพื้นฐานออฟเซ็ตคือ 115–118 dB; ห้องที่เงียบสงบควรอ่านได้ประมาณ 30–40 dB ปรับแต่งอย่างละเอียดด้วยมิเตอร์แบบมืออาชีพหากจำเป็น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mod farkı taban çizgisi 115–118 dB; sessiz bir oda yaklaşık 30–40 dB değerini okumalıdır. Gerekirse profesyonel bir ölçüm aletiyle ince ayar yapın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Базова лінія зміщення режиму становить 115–118 dB; у тихій кімнаті має бути близько 30–40 dB. За потреби виконайте точне налаштування за допомогою професійного глюкометра."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đường cơ sở bù chế độ là 115–118 dB; một căn phòng yên tĩnh nên đọc khoảng 30–40 dB. Tinh chỉnh bằng máy đo chuyên nghiệp nếu cần."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模式偏移基线约为 115–118 dB；安静房间读数约 30–40 dB。如有需要请用专业声级计微调。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模式偏移基線約為 115–118 dB；安靜房間讀數約 30–40 dB。如有需要請用專業聲級計微調。"
          }
        }
      }
    },
