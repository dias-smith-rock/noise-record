    "modeSwitch.infoSheet.standard.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulates human ear subjective perception. Perfect for tracking everyday environmental noise, traffic, and general disturbances."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟人耳主观听感，适合追踪日常环境噪声、交通噪声与一般干扰。"
          }
        }
      }
    },
