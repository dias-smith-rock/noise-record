    "recorder.monitoringRequired.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Записът, активиран с глас, се изпълнява по тръбопровода за наблюдение на живо. Стартирайте наблюдението, за да активирате автоматичното записване."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La gravació activada per veu s'executa a la canalització de monitorització en directe. Inicieu la supervisió per activar l'enregistrament automàtic."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlasem aktivovaný záznam běží na živém monitorovacím potrubí. Spusťte monitorování, abyste povolili automatické nahrávání."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Stemmeaktiveret optagelse kører på liveovervågningspipeline. Start overvågning for at aktivere automatisk optagelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die sprachaktivierte Aufzeichnung läuft über die Live-Überwachungspipeline. Starten Sie die Überwachung, um die automatische Aufzeichnung zu aktivieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εγγραφή που ενεργοποιείται με φωνή εκτελείται στον αγωγό ζωντανής παρακολούθησης. Ξεκινήστε την παρακολούθηση για να ενεργοποιήσετε την αυτόματη εγγραφή."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ääniaktivoitu tallennus suoritetaan live-seurantaputkessa. Aloita valvonta ottaaksesi automaattisen tallennuksen käyttöön."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הקלטה מופעלת קול פועלת על צינור הניטור החי. התחל במעקב כדי לאפשר הקלטה אוטומטית."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Snimanje aktivirano glasom radi na cjevovodu za praćenje uživo. Pokrenite nadzor kako biste omogućili automatsko snimanje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hanggal aktivált rögzítés az élő felügyeleti csővezetéken fut. Indítsa el a figyelést az automatikus rögzítés engedélyezéséhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perekaman yang diaktifkan dengan suara berjalan pada saluran pemantauan langsung. Mulai pemantauan untuk mengaktifkan perekaman otomatis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La registrazione ad attivazione vocale viene eseguita sulla pipeline di monitoraggio dal vivo. Avvia il monitoraggio per abilitare la registrazione automatica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声起動の録音はライブ モニタリング パイプラインで実行されます。監視を開始して自動録画を有効にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성 활성화 녹음은 실시간 모니터링 파이프라인에서 실행됩니다. 자동 녹음을 활성화하려면 모니터링을 시작하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Rakaman diaktifkan suara berjalan pada saluran paip pemantauan langsung. Mulakan pemantauan untuk membolehkan rakaman automatik."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Stemmeaktivert opptak kjører på live overvåkingsrørledningen. Start overvåking for å aktivere automatisk opptak."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spraakgestuurde opnames worden uitgevoerd via de live monitoringpijplijn. Start de monitoring om automatische opname in te schakelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagrywanie aktywowane głosem odbywa się w potoku monitorowania na żywo. Rozpocznij monitorowanie, aby włączyć automatyczne nagrywanie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înregistrarea activată prin voce rulează pe conducta de monitorizare în direct. Începeți monitorizarea pentru a activa înregistrarea automată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice-activated recording runs on the live monitoring pipeline. Start monitoring to enable auto-recording."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlasom aktivované nahrávanie beží na živom monitorovacom potrubí. Ak chcete povoliť automatické nahrávanie, spustite monitorovanie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Röstaktiverad inspelning körs på liveövervakningspipeline. Starta övervakning för att aktivera automatisk inspelning."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การบันทึกเสียงที่เปิดใช้งานด้วยเสียงทำงานบนไปป์ไลน์การตรวจสอบแบบสด เริ่มการตรวจสอบเพื่อเปิดใช้งานการบันทึกอัตโนมัติ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesle etkinleştirilen kayıt, canlı izleme hattında çalışır. Otomatik kaydı etkinleştirmek için izlemeyi başlatın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Голосовий запис виконується на конвеєрі моніторингу в реальному часі. Почніть моніторинг, щоб увімкнути автоматичний запис."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ghi âm kích hoạt bằng giọng nói chạy trên đường dẫn giám sát trực tiếp. Bắt đầu giám sát để bật tính năng ghi tự động."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "声控录音依赖实时监测。请先开始监测以启用自动录音。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "聲控錄音依賴即時監測。請先開始監測以啟用自動錄音。"
          }
        }
      }
    },
