        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απαγορεύτηκε η πρόσβαση στο μικρόφωνο. Ενεργοποιήστε το στις Ρυθμίσεις για να μετρήσετε το θόρυβο."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone access was denied. Enable it in Settings to measure noise."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se denegó el acceso al micrófono. Actívalo en Ajustes para medir el ruido."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofonin käyttö estettiin. Ota se käyttöön asetuksista mitataksesi melua."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès au micro a été refusé. Activez-le dans Réglages pour mesurer le bruit."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הגישה למיקרופון נדחתה. אפשר את זה בהגדרות כדי למדוד רעש."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफ़ोन एक्सेस अस्वीकृत। शोर मापने के लिए सेटिंग्स में चालू करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pristup mikrofonu je odbijen. Omogućite ga u postavkama za mjerenje buke."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A mikrofonhoz való hozzáférés megtagadva. Engedélyezze a Beállításokban a zaj méréséhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses mikrofon ditolak. Aktifkan di Pengaturan untuk mengukur kebisingan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso al microfono è stato negato. Abilitalo in Impostazioni per misurare il rumore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクへのアクセスが拒否されました。ノイズを測定するには、設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마이크 액세스가 거부되었습니다. 소음을 측정하려면 설정에서 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses mikrofon telah ditolak. Dayakannya dalam Tetapan untuk mengukur hingar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofontilgang ble nektet. Aktiver den i Innstillinger for å måle støy."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegang tot de microfoon is geweigerd. Schakel dit in Instellingen in om ruis te meten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odmowa dostępu do mikrofonu. Włącz tę opcję w Ustawieniach, aby mierzyć hałas."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso ao microfone foi negado. Ative em Ajustes para medir o ruído."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesul la microfon a fost interzis. Activați-l în Setări pentru a măsura zgomotul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к микрофону запрещён. Включите в «Настройках» для измерения шума."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prístup k mikrofónu bol odmietnutý. Ak chcete merať hluk, povoľte ho v Nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofonåtkomst nekades. Aktivera det i Inställningar för att mäta brus."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเข้าถึงไมโครโฟนถูกปฏิเสธ เปิดใช้งานในการตั้งค่าเพื่อวัดเสียงรบกวน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofon erişimi reddedildi. Gürültüyü ölçmek için Ayarlar'da etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "У доступі до мікрофона відмовлено. Увімкніть його в налаштуваннях, щоб вимірювати шум."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quyền truy cập micrô đã bị từ chối. Kích hoạt nó trong Cài đặt để đo tiếng ồn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "麦克风权限被拒绝。请在设置中开启以测量噪声。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "麥克風權限遭拒。請在設定中開啟以測量噪音。"
          }
        }
      }
    },
