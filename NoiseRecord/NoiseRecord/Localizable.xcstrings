    "silenceGrade.d.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضوضاء عالية أو مستمرة؛ يُنصح باتخاذ إجراء."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Силен или постоянен шум; препоръчва се коригиращо действие."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Soroll fort o persistent; acció correctiva recomanada."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlasitý nebo trvalý hluk; doporučeno nápravné opatření."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Høj eller vedvarende støj; korrigerende handling anbefales."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lauter oder anhaltender Lärm; Korrekturmaßnahme empfohlen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δυνατός ή επίμονος θόρυβος. συνιστάται διορθωτική δράση."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Loud or persistent noise; corrective action recommended."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruido alto o persistente; se recomienda actuar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kova tai jatkuva melu; korjaustoimenpiteitä suositellaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruit fort ou persistant ; action corrective recommandée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "רעש חזק או מתמשך; מומלצת פעולה מתקנת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तेज़ या लगातार शोर; सुधार की सिफ़ारिश।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glasna ili stalna buka; preporučena korektivna radnja."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hangos vagy tartós zaj; korrekciós intézkedés javasolt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kebisingan yang keras atau terus-menerus; tindakan korektif direkomendasikan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rumore forte o persistente; azione correttiva consigliata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "大きな騒音または持続的な騒音。修正措置を推奨します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시끄럽거나 지속적인 소음; 시정 조치가 권장됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunyi yang kuat atau berterusan; tindakan pembetulan disyorkan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Høy eller vedvarende støy; korrigerende tiltak anbefales."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Luid of aanhoudend geluid; corrigerende actie aanbevolen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Głośny lub ciągły hałas; zalecane działania naprawcze."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruído alto ou persistente; recomenda-se ação corretiva."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Zgomot puternic sau persistent; acțiune corectivă recomandată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Громкий или постоянный шум; рекомендуется устранить причину."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlasitý alebo pretrvávajúci hluk; odporúčané nápravné opatrenie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Högt eller ihållande ljud; korrigerande åtgärder rekommenderas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เสียงดังหรือต่อเนื่อง; แนะนำให้ดำเนินการแก้ไข"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüksek veya sürekli gürültü; düzeltici eylem önerilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Гучний або постійний шум; рекомендовані коригувальні дії."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiếng ồn lớn hoặc dai dẳng; hành động khắc phục được đề xuất."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "噪声较大或持续，建议采取改善措施。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "噪音較大或持續，建議採取改善措施。"
          }
        }
      }
    },
