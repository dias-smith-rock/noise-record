        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha apenas clipes dos tipos selecionados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранять только клипы выбранных типов звука."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅保留匹配所选声音类型的片段。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅保留符合所選聲音類型的片段。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Запазете само клипове, които отговарят на избрани типове звук."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserveu només els clips que coincideixin amb els tipus de so seleccionats."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uchovávejte pouze klipy, které odpovídají vybraným typům zvuku."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gem kun klip, der matcher udvalgte lydtyper."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalten Sie nur Clips, die den ausgewählten Soundtypen entsprechen."
          }
