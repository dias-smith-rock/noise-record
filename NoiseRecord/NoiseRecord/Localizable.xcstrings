    "silenceGrade.c.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضوضاء خلفية ملحوظة؛ قد تؤثر على النوم أو العمل."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Забележим фонов шум; може да повлияе на съня или работата."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Soroll de fons notable; pot afectar el son o el treball."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Znatelný hluk na pozadí; může ovlivnit spánek nebo práci."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mærkbar baggrundsstøj; kan påvirke søvn eller arbejde."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auffälliges Hintergrundgeräusch; kann den Schlaf oder die Arbeit beeinträchtigen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αξιοσημείωτος θόρυβος φόντου. μπορεί να επηρεάσει τον ύπνο ή την εργασία."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Noticeable background noise; may affect sleep or work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruido de fondo notable; puede afectar el sueño o el trabajo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Huomattava taustamelu; saattaa vaikuttaa uneen tai työhön."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruit de fond notable ; peut gêner le sommeil ou le travail."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "רעשי רקע ניכרים; עשוי להשפיע על השינה או העבודה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पृष्ठभूमि शोर स्पष्ट; नींद/काम प्रभावित हो सकता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Primjetna pozadinska buka; može utjecati na spavanje ili rad."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Észrevehető háttérzaj; befolyásolhatja az alvást vagy a munkát."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kebisingan latar belakang yang nyata; dapat mempengaruhi tidur atau pekerjaan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rumore di fondo notevole; può influenzare il sonno o il lavoro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "顕著な背景ノイズ。睡眠や仕事に影響を与える可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "눈에 띄는 배경 소음; 수면이나 업무에 영향을 미칠 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunyi latar belakang yang ketara; boleh menjejaskan tidur atau bekerja."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Merkbar bakgrunnsstøy; kan påvirke søvn eller arbeid."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Merkbaar achtergrondgeluid; kan de slaap of het werk beïnvloeden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zauważalny hałas w tle; może wpływać na sen lub pracę."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruído de fundo perceptível; pode afetar sono ou trabalho."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Zgomot de fond vizibil; poate afecta somnul sau munca."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заметный фоновый шум; может мешать сну или работе."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Znateľný hluk v pozadí; môže ovplyvniť spánok alebo prácu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Märkbart bakgrundsljud; kan påverka sömn eller arbete."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เสียงพื้นหลังที่เห็นได้ชัดเจน อาจส่งผลต่อการนอนหลับหรือการทำงาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikkat çekici arka plan gürültüsü; uykuyu veya çalışmayı etkileyebilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Помітний фоновий шум; може вплинути на сон або роботу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiếng ồn nền đáng chú ý; có thể ảnh hưởng đến giấc ngủ hoặc công việc."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "背景噪声明显，可能影响睡眠或工作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "背景噪音明顯，可能影響睡眠或工作。"
          }
        }
      }
    },
