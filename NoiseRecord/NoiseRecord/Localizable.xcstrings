    "dashboard.footer.highSensitivity": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "وضع الحساسية العالية: تعكس القراءات ضغط الصوت الفيزيائي لكامل النطاق."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим с висока чувствителност: показанията отразяват физическото звуково налягане в цялата лента."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode d'alta sensibilitat: les lectures reflecteixen la pressió sonora física de banda completa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Režim vysoké citlivosti: hodnoty odrážejí fyzický akustický tlak v celém pásmu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Højfølsomhedstilstand: aflæsninger afspejler det fysiske lydtryk i fuld bånd."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hochempfindlicher Modus: Die Messwerte spiegeln den gesamten physikalischen Schalldruck wider."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Λειτουργία υψηλής ευαισθησίας: οι ενδείξεις αντικατοπτρίζουν την φυσική ηχητική πίεση πλήρους ζώνης."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High-sensitivity mode: readings reflect full-band physical sound pressure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo de alta sensibilidad: las lecturas reflejan la presión sonora física de banda completa."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Korkean herkkyyden tila: lukemat heijastavat koko kaistan fyysistä äänenpainetta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode haute sensibilité : les mesures reflètent la pression acoustique physique pleine bande."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מצב רגישות גבוהה: קריאות משקפות לחץ צליל פיזי של פס מלא."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उच्च-संवेदनशीलता मोड: रीडिंग पूर्ण-बैंड भौतिक ध्वनि दबाव दर्शाती हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Način rada visoke osjetljivosti: očitanja odražavaju fizički zvučni tlak u cijelom pojasu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagy érzékenységű mód: a leolvasások a teljes sáv fizikai hangnyomását tükrözik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode sensitivitas tinggi: pembacaan mencerminkan tekanan suara fisik pita penuh."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Modalità ad alta sensibilità: le letture riflettono la pressione sonora fisica a banda intera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高感度モード: 測定値は全帯域の物理音圧を反映します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고감도 모드: 판독값은 전대역의 물리적 음압을 반영합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mod sensitiviti tinggi: bacaan mencerminkan tekanan bunyi fizikal jalur penuh."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Høyfølsomhetsmodus: avlesninger reflekterer fysisk lydtrykk i hele båndet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoge gevoeligheidsmodus: de metingen weerspiegelen de fysieke geluidsdruk over de volledige band."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryb wysokiej czułości: odczyty odzwierciedlają fizyczne ciśnienie akustyczne w pełnym paśmie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo de alta sensibilidade: as leituras refletem a pressão sonora física em banda completa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mod de înaltă sensibilitate: citirile reflectă presiunea sonoră fizică pe bandă completă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим высокой чувствительности: показания отражают физическое звуковое давление во всей полосе."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Režim vysokej citlivosti: hodnoty odrážajú fyzický akustický tlak v celom pásme."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Högkänslighetsläge: avläsningar återspeglar fysiskt ljudtryck i hela bandet."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โหมดความไวสูง: การอ่านสะท้อนถึงความดันเสียงทางกายภาพแบบเต็มแบนด์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüksek hassasiyet modu: okumalar tam bantlı fiziksel ses basıncını yansıtır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим високої чутливості: показання відображають фізичний звуковий тиск у повному діапазоні."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chế độ độ nhạy cao: số đọc phản ánh áp suất âm thanh vật lý toàn dải."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高灵敏度模式：读数反映全频段物理声压。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "高靈敏度模式：讀數反映全頻段物理聲壓。"
          }
        }
      }
    },
