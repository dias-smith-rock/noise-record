    "video.tips.watermarkBody": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُدمج قراءات الديسيبل وGPS (إن وُجد) في الفيديو كدليل."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Показанията в децибели и GPS (когато са налични) се записват във видеото за доказателство."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Les lectures de decibels i GPS (quan estiguin disponibles) es graven al vídeo com a prova."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibelové hodnoty a GPS (pokud je k dispozici) jsou vypáleny do videa jako důkaz."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibelaflæsninger og GPS (hvis de er tilgængelige) er brændt ind i videoen som bevis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dezibelwerte und GPS (sofern verfügbar) werden zu Beweiszwecken in das Video eingebrannt."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι ενδείξεις ντεσιμπέλ και το GPS (όταν είναι διαθέσιμο) καίγονται στο βίντεο για αποδεικτικά στοιχεία."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel readings and GPS (when available) are burned into the video for evidence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las lecturas en decibelios y el GPS (si está disponible) se incrustan en el vídeo como prueba."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Desibelilukemat ja GPS (jos saatavilla) poltetaan videoon todisteeksi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mesures en décibels et le GPS (si disponible) sont intégrés à la vidéo comme preuve."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קריאות דציבלים וGPS (כאשר זמינים) נצרבים בסרטון להוכחות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "dB रीडिंग और GPS (यदि उपलब्ध) साक्ष्य के लिए वीडियो में जोड़े जाते हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Očitavanje decibela i GPS (ako je dostupno) urezani su u video kao dokaz."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A decibelértékek és a GPS (ha elérhető) bizonyítékként beégetve vannak a videóba."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembacaan desibel dan GPS (bila tersedia) dimasukkan ke dalam video sebagai bukti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le letture in decibel e GPS (se disponibili) vengono impressi nel video come prova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デシベル測定値と GPS (利用可能な場合) が証拠としてビデオに焼き付けられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "증거를 위해 데시벨 수치와 GPS(사용 가능한 경우)이 비디오에 포함됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bacaan desibel dan GPS (apabila tersedia) dibakar ke dalam video untuk bukti."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Desibelavlesninger og GPS (når tilgjengelig) er brent inn i videoen for bevis."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibelmetingen en GPS (indien beschikbaar) worden als bewijs in de video gebrand."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczyty w decybelach i GPS (jeśli są dostępne) są nagrywane na wideo w celu uzyskania dowodów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Leituras em decibéis e GPS (quando disponível) são gravadas no vídeo como prova."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Citirile decibeli și GPS (dacă sunt disponibile) sunt inscripționate în videoclip pentru dovezi."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показания дБ и GPS (если доступно) встраиваются в видео как доказательство."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibelové hodnoty a GPS (ak je k dispozícii) sú vypálené do videa ako dôkaz."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibelavläsningar och GPS (när de är tillgängliga) bränns in i videon som bevis."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การอ่านค่าเดซิเบลและ GPS (หากมี) จะถูกเบิร์นลงในวิดีโอเพื่อเป็นหลักฐาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanıt olarak videoya desibel okumaları ve GPS (mevcut olduğunda) yazdırılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Показання в децибелах і GPS (за наявності) записуються у відео для підтвердження."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Số đo decibel và GPS (nếu có) được ghi vào video để làm bằng chứng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分贝读数和 GPS（如可用）会嵌入视频作为证据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "分貝讀數與 GPS（若可用）會嵌入影片作為證據。"
          }
        }
      }
    },
