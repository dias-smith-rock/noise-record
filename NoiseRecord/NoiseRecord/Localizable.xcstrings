    "recorderSettings.aiFilter.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احتفظ فقط بالمقاطع المطابقة للأنواع المحددة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only keep clips that match selected sound types."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserva solo clips que coincidan con los tipos seleccionados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne conserve que les clips correspondant aux types choisis."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल चुने ध्वनि प्रकार के क्लिप रखें।"
