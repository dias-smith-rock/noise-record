    "recorderSettings.thresholds.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدد متى يبدأ التسجيل ويتوقف."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Задайте кога записът започва и спира."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Estableix quan comença i s'atura la gravació."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavte, kdy se nahrávání spustí a zastaví."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indstil når optagelsen starter og stopper."
          }
