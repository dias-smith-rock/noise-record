        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie fest, wann die Aufnahme beginnt und stoppt."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ρυθμίστε την έναρξη και τη διακοπή της εγγραφής."
