    "permission.location.denied.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Местоположението не е задължително. Видеото все още може да бъде записано без GPS във водния знак. Активирайте местоположението в Настройки, за да вградите координати."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicació és opcional. El vídeo encara es pot gravar sense GPS a la marca d'aigua. Activa la ubicació a Configuració per incrustar les coordenades."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Umístění je volitelné. Video lze stále nahrávat bez GPS ve vodoznaku. Chcete-li vložit souřadnice, povolte polohu v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Placering er valgfri. Video kan stadig optages uden GPS i vandmærket. Aktiver placering i Indstillinger for at integrere koordinater."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Standort ist optional. Videos können weiterhin ohne GPS im Wasserzeichen aufgezeichnet werden. Aktivieren Sie den Standort in den Einstellungen, um Koordinaten einzubetten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η τοποθεσία είναι προαιρετική. Το βίντεο μπορεί ακόμα να εγγραφεί χωρίς GPS στο υδατογράφημα. Ενεργοποιήστε την τοποθεσία στις Ρυθμίσεις για ενσωμάτωση συντεταγμένων."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sijainti on valinnainen. Video voidaan silti tallentaa ilman GPS vesileimassa. Ota sijainti käyttöön asetuksista upottaaksesi koordinaatit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המיקום הוא אופציונלי. עדיין ניתן להקליט וידאו ללא GPS בסימן המים. אפשר מיקום בהגדרות כדי להטמיע קואורדינטות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokacija nije obavezna. Video se i dalje može snimati bez GPS u vodenom žigu. Omogućite lokaciju u postavkama za ugrađivanje koordinata."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A helyszín nem kötelező. A videó továbbra is rögzíthető anélkül, hogy GPS szerepelne a vízjelben. A koordináták beágyazásához engedélyezze a helyet a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi adalah opsional. Video tetap dapat direkam tanpa GPS di tanda air. Aktifkan lokasi di Pengaturan untuk menyematkan koordinat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La posizione è facoltativa. Il video può comunque essere registrato senza GPS nella filigrana. Abilita la posizione in Impostazioni per incorporare le coordinate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "場所はオプションです。ウォーターマークに GPS を入れなくてもビデオを録画できます。設定で位置情報を有効にして座標を埋め込みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위치는 선택사항입니다. 워터마크에 GPS 없이도 비디오를 녹화할 수 있습니다. 좌표를 삽입하려면 설정에서 위치를 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi adalah pilihan. Video masih boleh dirakam tanpa GPS dalam tera air. Dayakan lokasi dalam Tetapan untuk membenamkan koordinat."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Plassering er valgfritt. Video kan fortsatt tas opp uten GPS i vannmerket. Aktiver plassering i Innstillinger for å bygge inn koordinater."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatie is optioneel. Video kan nog steeds worden opgenomen zonder GPS in het watermerk. Schakel locatie in Instellingen in om coördinaten in te sluiten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokalizacja jest opcjonalna. Wideo można nadal nagrywać bez GPS w znaku wodnym. Włącz lokalizację w Ustawieniach, aby osadzić współrzędne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Locația este opțională. Videoclipul poate fi încă înregistrat fără GPS în filigran. Activați locația în Setări pentru a încorpora coordonatele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is optional. Video can still be recorded without GPS in the watermark. Enable location in Settings to embed coordinates."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Umiestnenie je voliteľné. Video je možné nahrávať aj bez GPS vo vodoznaku. Ak chcete vložiť súradnice, povoľte polohu v Nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Plats är valfritt. Video kan fortfarande spelas in utan GPS i vattenstämpeln. Aktivera plats i Inställningar för att bädda in koordinater."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สถานที่ตั้งเป็นทางเลือก วิดีโอยังคงสามารถบันทึกวิดีโอได้โดยไม่ต้องมี GPS ในลายน้ำ เปิดใช้งานตำแหน่งในการตั้งค่าเพื่อฝังพิกัด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konum isteğe bağlıdır. Video, filigranda GPS olmadan da kaydedilebilir. Koordinatları eklemek için Ayarlar'da konumu etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Розташування необов’язкове. Відео все ще можна записувати без GPS у водяному знаку. Увімкніть місцезнаходження в налаштуваннях, щоб вставити координати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vị trí là tùy chọn. Vẫn có thể quay video mà không có GPS trong hình mờ. Bật vị trí trong Cài đặt để nhúng tọa độ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定位为可选项。未授权时仍可录像，但水印中不会包含 GPS。如需嵌入坐标，请在设置中开启定位。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "定位為可選項。未授權時仍可錄影，但浮水印中不會包含 GPS。如需嵌入座標，請在設定中開啟定位。"
          }
        }
      }
    },
