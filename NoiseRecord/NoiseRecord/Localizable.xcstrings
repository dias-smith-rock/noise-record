    "settings.temperature.footer": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ينطبق على درجة الحرارة الموجودة على لوحة معلومات الشاشة وشاشة العرض LED بملء الشاشة."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Отнася се за температурата на таблото на монитора и дисплея на цял екран LED."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "S'aplica a la temperatura al tauler del monitor i a la pantalla completa LED."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Platí pro teplotu na palubní desce monitoru a celoobrazovkovém LED displeji."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gælder for temperatur på monitorens dashboard og fuldskærms LED display."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gilt für die Temperatur auf dem Monitor-Dashboard und der Vollbildanzeige."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ισχύει για τη θερμοκρασία στο ταμπλό της οθόνης και την οθόνη LED σε πλήρη οθόνη."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies to temperature on the monitor dashboard and fullscreen LED display."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se aplica a la temperatura en el tablero del monitor y en la pantalla LED de pantalla completa."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Koskee lämpötilaa näytön kojelaudalla ja koko näytön LED -näytöllä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'applique à la température sur le tableau de bord du moniteur et à l'affichage plein écran LED."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "חל על הטמפרטורה על לוח המחוונים של הצג ועל תצוגת LED במסך מלא."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मॉनिटर डैशबोर्ड और फ़ुलस्क्रीन LED डिस्प्ले पर तापमान पर लागू होता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Primjenjuje se na temperaturu na nadzornoj ploči monitora i prikaz preko cijelog zaslona LED."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hőmérsékletre vonatkozik a monitor műszerfalán és a teljes képernyős LED kijelzőn."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berlaku untuk suhu di dasbor monitor dan tampilan layar penuh LED."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si applica alla temperatura sul dashboard del monitor e sul display LED a schermo intero."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モニターのダッシュボードと全画面 LED ディスプレイの温度に適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모니터 대시보드 및 전체 화면 LED 디스플레이의 온도에 적용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Digunakan pada suhu pada papan pemuka monitor dan paparan skrin penuh LED."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjelder temperatur på skjermens dashbord og fullskjerm LED-skjerm."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geldt voor de temperatuur op het monitordashboard en LED-weergave op volledig scherm."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotyczy temperatury na panelu monitora i wyświetlaczu pełnoekranowym LED."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica-se à temperatura no painel do monitor e à exibição em tela cheia de LED."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Se aplică temperaturii de pe tabloul de bord al monitorului și de pe ecranul complet LED."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Применяется к температуре на приборной панели монитора и полноэкранном дисплее LED."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vzťahuje sa na teplotu na prístrojovej doske monitora a zobrazenie na celú obrazovku LED."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Gäller temperatur på monitorns instrumentpanel och helskärms LED display."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้กับอุณหภูมิบนแดชบอร์ดของจอภาพและการแสดงผลแบบเต็มหน้าจอ LED"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitör panosundaki ve tam ekran LED ekranındaki sıcaklık için geçerlidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Застосовується до температури на інформаційній панелі монітора та повноекранному дисплеї LED."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Áp dụng cho nhiệt độ trên bảng điều khiển màn hình và màn hình LED toàn màn hình."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于监测页与全屏 LED 看板的温度显示。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於監測頁與全螢幕 LED 看板的溫度顯示。"
          }
        }
      }
    },
