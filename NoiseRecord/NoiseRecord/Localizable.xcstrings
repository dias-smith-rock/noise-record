    "mode.standard.tooltipCopy" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[قياسي] الأقرب للسمع الذاتي. مناسب للكلام اليومي وضوضاء التلفاز والحشود أو نزاعات الجيران. معايير الضوضاء السكنية (مثل 45 dB ليلًا) مبنية على هذا الوضع."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Standard] Closest to subjective hearing. Best for everyday speech, TV noise, mall crowds, or neighbor disputes. Residential noise standards (e.g. 45 dB at night) are based on this mode."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Estándar] Lo más cercano a la audición subjetiva. Ideal para voz cotidiana, TV, multitudes o disputas vecinales. Las normas residenciales (p. ej. 45 dB de noche) se basan en este modo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Standard] Proche de l’audition subjective. Idéal pour la parole, la TV, les foules ou les voisins. Les normes résidentielles (ex. 45 dB la nuit) reposent sur ce mode."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[मानक] व्यक्तिपरक श्रवण के सबसे करीब। रोज़मर्रा की बातचीत, TV, भीड़ या पड़ोस विवाद के लिए। आवासीय मानक (जैसे रात में 45 dB) इसी पर आधारित।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Padrão] Mais próximo da audição subjetiva. Ideal para fala diária, TV, multidões ou disputas com vizinhos. Normas residenciais (ex.: 45 dB à noite) usam este modo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Стандарт] Ближе всего к субъективному слуху. Для речи, ТВ, толпы, соседей. Жилые нормы (напр. 45 dB ночью) основаны на этом режиме."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "【标准】最接近主观听感。适合日常说话、电视声、商场人群或邻里纠纷。住宅噪声标准（如夜间 45 dB）基于此模式。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "【標準】最接近主觀聽感。適合日常說話、電視聲、商場人群或鄰里糾紛。住宅噪音標準（如夜間 45 dB）基於此模式。"
          }
        }
      }
    },
    "mode.standard.tooltipHeadline" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
