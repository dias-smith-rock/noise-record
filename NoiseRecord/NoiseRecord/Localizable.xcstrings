    "settings.calibration.reset.alert.alreadyDefault.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يُضبط تعديل يدوي؛ لا شيء لإعادة الضبط.\n\nتعديل المستخدم: 0 dB (بدون إزاحة إضافية)\nإجمالي الإزاحة: %@\n\nيجب أن تقرأ غرفة هادئة نحو 30–40 dB."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Не е зададена ръчна настройка; нищо за нулиране.\n\nПотребителска корекция: 0 dB (без допълнително отместване)\nОбщо отместване: %@\n\nТиха стая трябва да бъде около 30–40 dB."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No es va establir cap ajust manual; res a restablir.\n\nAjust d'usuari: 0 dB (sense compensació addicional)\nDesplaçament total: %@\n\nUna habitació tranquil·la hauria de llegir entre 30 i 40 dB."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nebylo nastaveno žádné ruční nastavení; není co resetovat.\n\nUživatelská úprava: 0 dB (bez dalšího posunu)\nCelkový posun: %@\n\nTichá místnost by měla mít hodnotu 30–40 dB."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der blev ikke indstillet nogen manuel justering; intet at nulstille.\n\nBrugerjustering: 0 dB (ingen ekstra offset)\nSamlet offset: %@\n\nEt stille rum bør læse omkring 30–40 dB."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wurde keine manuelle Anpassung vorgenommen; nichts zum Zurücksetzen.\n\nBenutzeranpassung: 0 dB (kein zusätzlicher Offset)\nGesamtoffset: %@\n\nEin ruhiger Raum sollte etwa 30–40 dB betragen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν έχει οριστεί χειροκίνητη ρύθμιση. τίποτα για επαναφορά.\n\nΠροσαρμογή χρήστη: 0 dB (χωρίς επιπλέον μετατόπιση)\nΣυνολική μετατόπιση: %@\n\nΈνα ήσυχο δωμάτιο θα πρέπει να διαβάζει περίπου 30–40 dB."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No manual adjustment was set; nothing to reset.\n\nUser adjustment: 0 dB (no extra offset)\nTotal offset: %@\n\nA quiet room should read about 30–40 dB."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No había ajuste manual; nada que restablecer.\n\nAjuste del usuario: 0 dB (sin offset extra)\nOffset total: %@\n\nUna habitación tranquila debería marcar unos 30–40 dB."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käsisäätöä ei ole asetettu; mitään nollattavaa.\n\nKäyttäjän oikaisu: 0 dB (ei ylimääräistä siirtymää)\nKokonaispoikkeama: %@\n\nHiljaisessa huoneessa tulisi lukea noin 30–40 dB."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun ajustement manuel ; rien à réinitialiser.\n\nAjustement utilisateur : 0 dB (pas d’offset)\nOffset total : %@\n\nUne pièce calme devrait afficher environ 30–40 dB."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לא נקבעה התאמה ידנית; אין מה לאפס.\n\nהתאמת משתמש: 0 dB (ללא היסט נוסף)\nסה\"כ היסט: %@\n\nחדר שקט צריך לקרוא בערך 30–40 dB."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई मैनुअल समायोजन नहीं था; रीसेट करने को कुछ नहीं।\n\nउपयोगकर्ता समायोजन: 0 dB (कोई अतिरिक्त ऑफ़सेट नहीं)\nकुल ऑफ़सेट: %@\n\nशांत कमरे में लगभग 30–40 dB दिखना चाहिए।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nije postavljeno ručno podešavanje; ništa za resetirati.\n\nKorisnička prilagodba: 0 dB (bez dodatnog pomaka)\nUkupni pomak: %@\n\nTiha soba trebala bi iznositi oko 30–40 dB."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs kézi beállítás beállítva; nincs mit visszaállítani.\n\nFelhasználói korrekció: 0 dB (nincs extra eltolás)\nTeljes eltolás: %@\n\nEgy csendes szobában körülbelül 30–40 dB olvasható."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada penyesuaian manual yang ditetapkan; tidak ada yang perlu diatur ulang.\n\nPenyesuaian pengguna: 0 dB (tidak ada offset tambahan)\nTotal offset: %@\n\nRuangan yang tenang harus membaca sekitar 30–40 dB."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non è stata impostata alcuna regolazione manuale; niente da resettare.\n\nRegolazione utente: 0 dB (nessun offset aggiuntivo)\nScostamento totale: %@\n\nUna stanza tranquilla dovrebbe leggere circa 30–40 dB."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動調整は設定されていませんでした。リセットするものは何もありません。\n\nユーザー調整: 0 dB (追加のオフセットなし)\n合計オフセット: %@\n\n静かな部屋では、約 30 ～ 40 dB が表示されるはずです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 조정이 설정되지 않았습니다. 재설정할 것이 없습니다.\n\n사용자 조정: 0 dB(추가 오프셋 없음)\n총 오프셋: %@\n\n조용한 방은 30-40 dB 정도 되어야 합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada pelarasan manual ditetapkan; tiada apa yang perlu ditetapkan semula.\n\nPelarasan pengguna: 0 dB (tiada offset tambahan)\nJumlah offset: %@\n\nBilik yang sunyi sepatutnya membaca kira-kira 30–40 dB."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen manuell justering ble stilt inn; ingenting å tilbakestille.\n\nBrukerjustering: 0 dB (ingen ekstra forskyvning)\nTotal offset: %@\n\nEt stille rom bør lese ca 30–40 dB."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is geen handmatige aanpassing ingesteld; niets te resetten.\n\nGebruikersaanpassing: 0 dB (geen extra offset)\nTotale compensatie: %@\n\nEen rustige kamer zou ongeveer 30–40 dB moeten lezen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie ustawiono ręcznej regulacji; nic do resetowania.\n\nRegulacja użytkownika: 0 dB (bez dodatkowego przesunięcia)\nCałkowite przesunięcie: %@\n\nCichy pokój powinien czytać około 30–40 dB."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum ajuste manual definido; nada a redefinir.\n\nAjuste do usuário: 0 dB (sem offset extra)\nOffset total: %@\n\nUm ambiente silencioso deve marcar cerca de 30–40 dB."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu a fost setată nicio reglare manuală; nimic de resetat.\n\nAjustare utilizator: 0 dB (fără compensare suplimentară)\nCompensație totală: %@\n\nO cameră liniștită ar trebui să indice aproximativ 30–40 dB."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ручная поправка не задана; сбрасывать нечего.\n\nПользовательская поправка: 0 dB (без доп. смещения)\nСуммарное смещение: %@\n\nВ тихой комнате должно быть около 30–40 dB."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nebolo nastavené žiadne manuálne nastavenie; nie je čo resetovať.\n\nPoužívateľská úprava: 0 dB (bez dodatočného posunu)\nCelkový posun: %@\n\nTichá miestnosť by mala mať hodnotu 30–40 dB."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen manuell justering ställdes in; inget att återställa.\n\nAnvändarjustering: 0 dB (ingen extra offset)\nTotal offset: %@\n\nEtt tyst rum bör läsa ca 30–40 dB."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีการตั้งค่าการปรับด้วยตนเอง ไม่มีอะไรจะรีเซ็ต\n\nการปรับโดยผู้ใช้: 0 dB (ไม่มีออฟเซ็ตเพิ่มเติม)\nออฟเซ็ตทั้งหมด: %@\n\nห้องที่เงียบสงบควรอ่านได้ประมาณ 30–40 dB"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Herhangi bir manuel ayar yapılmadı; sıfırlanacak bir şey yok.\n\nKullanıcı ayarı: 0 dB (ekstra ofset yok)\nToplam sapma: %@\n\nSessiz bir oda yaklaşık 30–40 dB değerini okumalıdır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ручне регулювання не встановлено; нічого не скидати.\n\nКоригування користувача: 0 dB (без додаткового зміщення)\nЗагальне зміщення: %@\n\nУ тихій кімнаті має бути приблизно 30–40 dB."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có điều chỉnh thủ công nào được đặt; không có gì để thiết lập lại.\n\nĐiều chỉnh của người dùng: 0 dB (không có phần bù thêm)\nTổng số tiền bù đắp: %@\n\nPhòng yên tĩnh nên đọc khoảng 30–40 dB."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未设置手动调整，无需重置。\n\n用户调整：0 dB（无额外偏移）\n总偏移：%@\n\n安静房间读数约 30–40 dB。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未設定手動調整，無需重置。\n\n使用者調整：0 dB（無額外偏移）\n總偏移：%@\n\n安靜房間讀數約 30–40 dB。"
          }
        }
      }
    },
    "settings.calibration.reset.alert.alreadyDefault.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
