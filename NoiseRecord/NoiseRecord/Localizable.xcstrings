    "settings.weighting.footer": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الترجيح A يقارب السمع البشري؛ يُستخدمان C وZ للتحليل التقني وكامل النطاق."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A-weighting matches human hearing; C and Z are used for technical and full-band analysis."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ponderación A se aproxima a la audición humana; C y Z se usan para análisis técnico y de banda completa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La pondération A suit l’audition humaine ; C et Z servent à l’analyse technique et pleine bande."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "A-भारण मानव श्रवण के करीब है; C और Z तकनीकी/पूर्ण-बैंड विश्लेषण के लिए।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A ponderação A aproxima a audição humana; C e Z são usadas para análise técnica e de banda completa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "A-взвешивание близко к слуху человека; C и Z — для технического и полнополосного анализа."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "A 计权贴近人耳听感；C 与 Z 用于技术与全频段分析。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "A 計權貼近人耳聽感；C 與 Z 用於技術與全頻段分析。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "A-теглото съответства на човешкия слух; C и Z се използват за технически и пълночестотен анализ."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La ponderació A coincideix amb l'oïda humana; C i Z s'utilitzen per a l'anàlisi tècnica i de banda completa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "A-váha odpovídá lidskému sluchu; C a Z se používají pro technickou a celopásmovou analýzu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "A-vægtning matcher menneskelig hørelse; C og Z bruges til teknisk og full-band analyse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die A-Gewichtung entspricht dem menschlichen Gehör; C und Z werden für die technische Analyse und die Vollbandanalyse verwendet."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η στάθμιση A ταιριάζει με την ανθρώπινη ακοή. Τα C και Z χρησιμοποιούνται για τεχνική ανάλυση και ανάλυση πλήρους ζώνης."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "A-painotus vastaa ihmisen kuuloa; C:tä ja Z:tä käytetään tekniseen ja koko kaistan analysointiin."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שקלול A תואם את השמיעה האנושית; C ו-Z משמשים לניתוח טכני ופס מלא."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "A-ponderiranje odgovara ljudskom sluhu; C i Z se koriste za tehničku analizu i analizu cijelog pojasa."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az A-súlyozás megfelel az emberi hallásnak; A C-t és a Z-t technikai és teljes sávos elemzéshez használják."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembobotan A cocok dengan pendengaran manusia; C dan Z digunakan untuk analisis teknis dan full-band."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La ponderazione A corrisponde all'udito umano; C e Z vengono utilizzati per l'analisi tecnica e a banda intera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "A 重み付けは人間の聴覚に一致します。 C と Z はテクニカル分析とフルバンド分析に使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "A-가중치는 인간의 청력과 일치합니다. C와 Z는 기술 및 전대역 분석에 사용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemberatan A sepadan dengan pendengaran manusia; C dan Z digunakan untuk analisis teknikal dan jalur penuh."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "A-vekting matcher menneskelig hørsel; C og Z brukes til teknisk og fullbåndsanalyse."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "A-weging komt overeen met het menselijk gehoor; C en Z worden gebruikt voor technische en volledige bandanalyse."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ważenie A odpowiada ludzkiemu słuchowi; C i Z służą do analizy technicznej i pełnopasmowej."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponderarea A se potrivește cu auzul uman; C și Z sunt utilizate pentru analiza tehnică și în bandă completă."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "A-váha zodpovedá ľudskému sluchu; C a Z sa používajú na technickú a celopásmovú analýzu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "A-viktning matchar mänsklig hörsel; C och Z används för teknisk analys och fullbandsanalys."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "A-weighting ตรงกับการได้ยินของมนุษย์ C และ Z ใช้สำหรับการวิเคราะห์ทางเทคนิคและการวิเคราะห์แบบเต็มแบนด์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "A-ağırlıklandırma insan işitmesiyle eşleşir; C ve Z teknik ve tam bant analiz için kullanılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "A-зважування відповідає людському слуху; C і Z використовуються для технічного та повнодіапазонного аналізу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trọng số A phù hợp với thính giác của con người; C và Z được sử dụng để phân tích kỹ thuật và toàn dải."
          }
        }
      }
    },
