    "mode.highSensitivity.comparisonHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القراءات غالبًا أعلى من الوضع القياسي—هذا طبيعي؛ يقيس صوتًا قد لا تسمعه لكنه موجود."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Показанията често са по-високи от стандартния режим - това е нормално; той измерва звук, който може да не чуете, но все още е там."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Les lectures solen ser més altes que el mode estàndard, això és normal; mesura el so que potser no escolteu, però encara hi és."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hodnoty jsou často vyšší než ve standardním režimu – to je normální; měří zvuk, který možná neslyšíte, ale stále existuje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Aflæsninger er ofte højere end standardtilstand - det er normalt; den måler lyd, du måske ikke hører, men som stadig er der."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Messwerte sind oft höher als im Standardmodus – das ist normal; Es misst Geräusche, die Sie möglicherweise nicht hören, die aber dennoch vorhanden sind."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι μετρήσεις είναι συχνά υψηλότερες από την τυπική λειτουργία—αυτό είναι φυσιολογικό. μετρά τον ήχο που μπορεί να μην ακούτε αλλά είναι ακόμα εκεί."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Readings are often higher than standard mode—that is normal; it measures sound you may not hear but is still there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las lecturas suelen ser más altas que en modo estándar—es normal; mide sonido que quizá no oyes pero está ahí."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lukemat ovat usein korkeampia kuin standarditila – tämä on normaalia; se mittaa ääntä, jota et ehkä kuule, mutta on silti olemassa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mesures sont souvent plus hautes qu’en standard—c’est normal ; elles mesurent du son inaudible mais présent."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הקריאות לרוב גבוהות יותר ממצב רגיל - זה נורמלי; הוא מודד צליל שאולי לא שומע אבל עדיין שם."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडिंग अक्सर मानक से अधिक—यह सामान्य है; ऐसी ध्वनि मापता है जो सुनाई न दे पर मौजूद हो।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Očitanja su često veća od standardnog načina rada—to je normalno; mjeri zvuk koji možda ne čujete, ali je još uvijek tu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az értékek gyakran magasabbak, mint a normál módban – ez normális; olyan hangot mér, amelyet esetleg nem hall, de még mindig ott van."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembacaan seringkali lebih tinggi dari mode standar—itu normal; itu mengukur suara yang mungkin tidak Anda dengar tetapi masih ada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le letture sono spesso più elevate rispetto alla modalità standard: questo è normale; misura il suono che potresti non sentire ma è ancora lì."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "多くの場合、測定値は標準モードよりも高くなりますが、これは正常です。聞こえないかもしれないがまだ存在している音を測定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "판독값은 표준 모드보다 높은 경우가 많습니다. 이는 정상입니다. 들을 수는 없지만 여전히 존재하는 소리를 측정합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bacaan selalunya lebih tinggi daripada mod standard—itu adalah perkara biasa; ia mengukur bunyi yang mungkin anda tidak dengar tetapi masih ada."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Avlesningene er ofte høyere enn standardmodus – det er normalt; den måler lyd du kanskje ikke hører, men som fortsatt er der."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De meetwaarden zijn vaak hoger dan in de standaardmodus – dat is normaal; het meet geluid dat u misschien niet hoort, maar er nog steeds is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczyty są często wyższe niż w trybie standardowym – jest to normalne; mierzy dźwięk, którego możesz nie słyszeć, ale nadal tam jest."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As leituras costumam ser maiores que no modo padrão—é normal; mede som que você talvez não ouça, mas está lá."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Citirile sunt adesea mai mari decât modul standard - asta este normal; măsoară sunetul pe care s-ar putea să nu îl auzi, dar este încă acolo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показания часто выше стандартного режима—это нормально; измеряется звук, который вы можете не слышать."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Hodnoty sú často vyššie ako v štandardnom režime – to je normálne; meria zvuk, ktorý možno nepočujete, ale stále existuje."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Avläsningarna är ofta högre än standardläget – det är normalt; den mäter ljud som du kanske inte hör men som fortfarande finns där."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การอ่านมักจะสูงกว่าโหมดมาตรฐาน ซึ่งเป็นเรื่องปกติ โดยจะวัดเสียงที่คุณอาจไม่ได้ยินแต่ยังคงอยู่ที่นั่น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Okumalar genellikle standart moddan daha yüksektir; bu normaldir; Duymadığınız ama hâlâ orada olan sesi ölçer."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Показники часто вищі, ніж у стандартному режимі — це нормально; він вимірює звук, який ви можете не почути, але все ще є."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Số đọc thường cao hơn chế độ tiêu chuẩn—điều đó là bình thường; nó đo âm thanh mà bạn có thể không nghe thấy nhưng vẫn ở đó."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读数常高于标准模式——属正常；它测量您可能听不见但仍存在的声音。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀數常高於標準模式——屬正常；它測量您可能聽不見但仍存在的聲音。"
          }
        }
      }
    },
    "mode.highSensitivity.coreDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعطّل مرشحات السمع وقمع ضوضاء النظام لالتقاط طاقة الصوت الفيزيائية كاملة."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Деактивира слухово претеглените филтри и системното шумопотискане, за да улови пълната физическа звукова енергия."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactiva els filtres ponderats per l'audició i la supressió del soroll del sistema per capturar tota l'energia del so físic."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivuje sluchově vážené filtry a potlačení šumu systému pro zachycení plné fyzické zvukové energie."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktiverer hørevægtede filtre og systemstøjdæmpning for at fange fuld fysisk lydenergi."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktiviert gehörgewichtete Filter und Systemgeräuschunterdrückung, um die volle physische Schallenergie zu erfassen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απενεργοποιεί τα σταθμισμένα φίλτρα ακοής και την καταστολή θορύβου του συστήματος για να συλλάβει την πλήρη φυσική ηχητική ενέργεια."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disables hearing-weighted filters and system noise suppression to capture full physical sound energy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactiva filtros de audición y supresión de ruido del sistema para captar toda la energía sonora física."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Poistaa käytöstä kuulopainotetut suodattimet ja järjestelmän kohinanvaimennus täydellisen fyysisen äänienergian kaappaamiseksi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactive les filtres d’audition et la suppression système pour capturer toute l’énergie acoustique physique."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "משבית מסננים משוקלל שמיעה ודיכוי רעשי מערכת כדי ללכוד אנרגיית צליל פיזית מלאה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "श्रवण-भारित फ़िल्टर और सिस्टम शोर दमन बंद कर पूर्ण भौतिक ध्वनि ऊर्जा पकड़ता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Onemogućuje filtre mjerene sluhom i potiskivanje buke sustava radi hvatanja pune fizičke zvučne energije."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Letiltja a hallássúlyos szűrőket és a rendszerzaj-elnyomást a teljes fizikai hangenergia rögzítése érdekében."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menonaktifkan filter yang membebani pendengaran dan peredam bising sistem untuk menangkap energi suara fisik secara penuh."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabilita i filtri ponderati per l'udito e la soppressione del rumore del sistema per catturare tutta l'energia sonora fisica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "聴覚に重点を置いたフィルターとシステムのノイズ抑制を無効にして、物理的な音響エネルギーをすべてキャプチャします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "완전한 물리적 소리 에너지를 포착하기 위해 청각 가중치 필터 및 시스템 소음 억제를 비활성화합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Melumpuhkan penapis berwajaran pendengaran dan penindasan hingar sistem untuk menangkap tenaga bunyi fizikal sepenuhnya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktiverer hørselsvektede filtre og systemstøydemping for å fange opp full fysisk lydenergi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakelt gehoorgewogen filters en systeemruisonderdrukking uit om de volledige fysieke geluidsenergie op te vangen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyłącza filtry korygujące słuch i tłumienie hałasu w celu przechwytywania pełnej fizycznej energii dźwięku."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Desativa filtros de audição e supressão de ruído do sistema para capturar toda a energia sonora física."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dezactivează filtrele ponderate în funcție de auz și suprimarea zgomotului de sistem pentru a capta energia acustică fizică completă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключает слуховые фильтры и подавление шума системы для полной физической энергии звука."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivuje filtre so zaťažením sluchu a potlačenie šumu systému na zachytenie plnej fyzickej zvukovej energie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaktiverar hörselviktade filter och systembrusdämpning för att fånga upp full fysisk ljudenergi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดใช้งานตัวกรองน้ำหนักการได้ยินและการลดเสียงรบกวนของระบบเพื่อจับพลังงานเสียงทางกายภาพได้เต็มที่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tam fiziksel ses enerjisini yakalamak için işitme ağırlıklı filtreleri ve sistem gürültüsünü bastırmayı devre dışı bırakır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вимикає фільтри, зважені на слух, і системне придушення шуму для захоплення повної фізичної звукової енергії."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tắt các bộ lọc điều chỉnh thính giác và tính năng khử tiếng ồn của hệ thống để thu được toàn bộ năng lượng âm thanh vật lý."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭听感计权滤波与系统降噪，以捕捉完整物理声能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉聽感計權濾波與系統降噪，以捕捉完整物理聲能。"
          }
        }
      }
    },
