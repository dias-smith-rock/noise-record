    "mode.highSensitivity.tooltipCopy": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "[حساسية عالية] يلتقط الطاقة الفيزيائية الحقيقية في الهواء. ليلًا قد يلتقط التكييف والضواغط وأنابيب قد لا تلاحظها. القراءات أعلى عادة—مثالي للمصادر الخفية والأعطال والأدلة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "[High Sensitivity] Captures true physical energy in the air. In a quiet room at night it can pick up AC units, fridge compressors, and pipe rumble you may not notice. Readings are usually higher—ideal for hidden noise sources, machine faults, and evidence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "[Alta sensibilidad] Captura la energía física real en el aire. De noche puede detectar aires acondicionados, compresores y tuberías que no notas. Las lecturas suelen ser más altas—ideal para fuentes ocultas, fallos y pruebas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "[Haute sensibilité] Capture l’énergie physique réelle dans l’air. La nuit, détecte climatisation, compresseurs, tuyaux inaudibles. Mesures souvent plus hautes—idéal pour sources cachées, pannes et preuves."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "[उच्च संवेदनशीलता] हवा में वास्तविक भौतिक ऊर्जा पकड़ता है। रात में AC, कंप्रेसर, पाइप की गड़गड़ाहट जो सुनाई न दे। रीडिंग अक्सर अधिक—छिपे स्रोत, खराबी, साक्ष्य के लिए।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "[Alta sensibilidade] Captura a energia física real no ar. À noite pode pegar AC, compressores e tubulações que você não percebe. Leituras costumam ser maiores—ideal para fontes ocultas, falhas e provas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "[Высокая чувствительность] Захватывает реальную физическую энергию в воздухе. Ночью слышит кондиционеры, компрессоры, трубы. Показания обычно выше—для скрытых источников, неисправностей и доказательств."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "【高灵敏度】捕捉空气中的真实物理能量。夜间安静房间可测到空调、冰箱压缩机、管道轰鸣等不易察觉的声音。读数通常更高——适合隐蔽噪声源、设备故障与取证。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "【高靈敏度】捕捉空氣中的真實物理能量。夜間安靜房間可測到冷氣、冰箱壓縮機、管線轟鳴等不易察覺的聲音。讀數通常更高——適合隱蔽噪音源、設備故障與取證。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "[Висока чувствителност] Улавя истинската физическа енергия във въздуха. В тиха стая през нощта може да засече климатици, компресори на хладилник и тътен на тръби, който може да не забележите. Показанията обикновено са по-високи - идеални за скрити източници на шум, неизправности на машината и доказателства."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "[Alta sensibilitat] Capta l'energia física real a l'aire. En una habitació tranquil·la a la nit, pot recollir unitats d'aire condicionat, compressors de nevera i remor de canonades que potser no ho noteu. Les lectures solen ser més altes, ideals per a fonts de soroll ocultes, errors de la màquina i proves."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "[Vysoká citlivost] Zachycuje skutečnou fyzickou energii ve vzduchu. V tiché místnosti v noci může zachytit klimatizační jednotky, kompresory chladničky a rachot potrubí, kterého si nemusíte všimnout. Hodnoty jsou obvykle vyšší – ideální pro skryté zdroje hluku, závady stroje a důkazy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "[Høj følsomhed] Fanger ægte fysisk energi i luften. I et stille rum om natten kan den opfange AC-enheder, køleskabskompressorer og rørbuller, som du måske ikke bemærker. Aflæsninger er normalt højere - ideelle til skjulte støjkilder, maskinfejl og beviser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "[Hohe Empfindlichkeit] Erfasst echte physische Energie in der Luft. In einem ruhigen Raum kann es nachts zu Klimaanlagen, Kühlschrankkompressoren und Rohrgeräuschen kommen, die Sie möglicherweise nicht bemerken. Die Messwerte sind in der Regel höher – ideal für versteckte Geräuschquellen, Maschinenfehler und Beweise."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "[Υψηλή ευαισθησία] Αιχμαλωτίζει την πραγματική φυσική ενέργεια στον αέρα. Σε ένα ήσυχο δωμάτιο τη νύχτα, μπορεί να πάρει μονάδες AC, συμπιεστές ψυγείου και σωλήνες που μπορεί να μην παρατηρήσετε. Οι μετρήσεις είναι συνήθως υψηλότερες—ιδανικές για κρυφές πηγές θορύβου, σφάλματα μηχανής και στοιχεία."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "[Suuri herkkyys] Vangitsee todellista fyysistä energiaa ilmassa. Hiljaisessa huoneessa yöllä se voi poimia vaihtovirtayksiköitä, jääkaapin kompressoreja ja putkien kohinaa, jota et ehkä huomaa. Lukemat ovat yleensä korkeampia – ihanteellisia piilotetuille melulähteille, konevioille ja todisteille."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "[רגישות גבוהה] לוכדת אנרגיה פיזית אמיתית באוויר. בחדר שקט בלילה הוא יכול לקלוט יחידות AC, מדחסי מקררים ורחש צינור שאולי לא תבחין בהם. הקריאות בדרך כלל גבוהות יותר - אידיאלי עבור מקורות רעש נסתרים, תקלות במכונה וראיות."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "[Visoka osjetljivost] Hvata pravu fizičku energiju u zraku. U tihoj sobi noću može pokupiti klima uređaje, kompresore hladnjaka i tutnjavu cijevi koju možda nećete primijetiti. Očitavanja su obično veća—idealno za skrivene izvore buke, kvarove stroja i dokaze."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "[Nagy érzékenység] Valódi fizikai energiát rögzít a levegőben. Egy csendes helyiségben éjszaka felveszi a váltakozó áramú egységeket, a hűtőkompresszorokat és a csőzörgést, amelyet esetleg észre sem vesz. Az értékek általában magasabbak – ideális rejtett zajforrásokhoz, géphibákhoz és bizonyítékokhoz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "[Sensitivitas Tinggi] Menangkap energi fisik sebenarnya di udara. Di ruangan yang tenang di malam hari, unit AC, kompresor lemari es, dan suara gemuruh pipa dapat terdengar yang mungkin tidak Anda sadari. Pembacaan biasanya lebih tinggi—ideal untuk sumber kebisingan tersembunyi, kesalahan mesin, dan bukti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "[Alta sensibilità] Cattura la vera energia fisica nell'aria. Di notte, in una stanza tranquilla, può captare unità AC, compressori di frigoriferi e rumori di tubi che potresti non notare. Le letture sono generalmente più elevate, ideali per fonti di rumore nascoste, guasti alle macchine e prove."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "【高感度】空気中の真の物理エネルギーを捉えます。夜の静かな部屋では、ACユニット、冷蔵庫のコンプレッサー、気付かないかもしれない配管の騒音を拾うことがあります。通常、読み取り値は高くなります。隠れたノイズ源、機械の故障、証拠に最適です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "[고감도] 공중의 진정한 물리적 에너지를 포착합니다. 밤에 조용한 방에서는 AC 장치, 냉장고 압축기 및 파이프 소음을 감지할 수 없습니다. 판독값은 일반적으로 더 높으므로 숨겨진 소음원, 기계 결함 및 증거에 이상적입니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "[Sensitiviti Tinggi] Menangkap tenaga fizikal sebenar di udara. Di dalam bilik yang sunyi pada waktu malam, ia boleh mengambil unit AC, pemampat peti sejuk, dan bunyi paip yang mungkin anda tidak perasan. Bacaan biasanya lebih tinggi—sesuai untuk sumber hingar tersembunyi, kerosakan mesin dan bukti."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "[Høy følsomhet] Fanger ekte fysisk energi i luften. I et stille rom om natten kan den plukke opp AC-enheter, kjøleskapskompressorer og rørbuller du kanskje ikke legger merke til. Avlesningene er vanligvis høyere – ideell for skjulte støykilder, maskinfeil og bevis."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "[Hoge gevoeligheid] Vangt echte fysieke energie in de lucht op. In een stille kamer kan hij 's nachts AC-units, koelkastcompressoren en pijpgerommel opvangen dat u misschien niet opmerkt. De meetwaarden zijn doorgaans hoger, ideaal voor verborgen geluidsbronnen, machinefouten en bewijsmateriaal."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "[Wysoka czułość] Przechwytuje prawdziwą energię fizyczną z powietrza. W cichym pomieszczeniu w nocy może wychwycić klimatyzatory, sprężarki lodówek i dudnienie rur, których możesz nie zauważyć. Odczyty są zwykle wyższe — idealne rozwiązanie w przypadku ukrytych źródeł hałasu, usterek maszyn i dowodów."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "[Sensibilitate ridicată] Captează adevărata energie fizică din aer. Într-o cameră liniștită noaptea, poate ridica unități de aer condiționat, compresoare de frigider și zgomot de țevi pe care s-ar putea să nu-l observi. Citirile sunt de obicei mai mari - ideale pentru surse de zgomot ascunse, defecțiuni ale mașinii și dovezi."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "[Vysoká citlivosť] Zachytáva skutočnú fyzickú energiu vo vzduchu. V tichej miestnosti v noci dokáže zachytiť klimatizačné jednotky, kompresory chladničky a rachot potrubia, ktorý si možno nevšimnete. Hodnoty sú zvyčajne vyššie – ideálne pre skryté zdroje hluku, poruchy stroja a dôkazy."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "[Hög känslighet] Fångar verklig fysisk energi i luften. I ett tyst rum på natten kan den plocka upp AC-enheter, kylkompressorer och rörbuller som du kanske inte märker. Avläsningarna är vanligtvis högre – idealiska för dolda bruskällor, maskinfel och bevis."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "[ความไวแสงสูง] จับพลังงานทางกายภาพที่แท้จริงในอากาศ ในห้องที่เงียบสงบในเวลากลางคืน มันสามารถจับเครื่องปรับอากาศ คอมเพรสเซอร์ตู้เย็น และเสียงท่อดังที่คุณอาจไม่สังเกตเห็น โดยทั่วไปการอ่านค่าจะสูงกว่า เหมาะสำหรับแหล่งกำเนิดเสียงรบกวนที่ซ่อนอยู่ เครื่องจักรทำงานผิดปกติ และหลักฐาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "[Yüksek Hassasiyet] Havadaki gerçek fiziksel enerjiyi yakalar. Geceleri sessiz bir odada klima ünitelerini, buzdolabı kompresörlerini ve fark etmeyebileceğiniz boru gürültüsünü algılayabilir. Okumalar genellikle daha yüksektir; gizli gürültü kaynakları, makine arızaları ve kanıtlar için idealdir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "[Висока чутливість] Зберігає справжню фізичну енергію в повітрі. У тихій кімнаті вночі він може підхопити блоки змінного струму, компресори холодильника та гул труб, який ви можете не помітити. Показання зазвичай вищі — ідеально підходить для прихованих джерел шуму, несправностей машини та доказів."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "[Độ nhạy cao] Thu được năng lượng vật lý thực sự trong không khí. Trong một căn phòng yên tĩnh vào ban đêm, nó có thể thu được các thiết bị AC, máy nén tủ lạnh và tiếng ồn của đường ống mà bạn có thể không nhận thấy. Số đọc thường cao hơn—lý tưởng cho các nguồn tiếng ồn ẩn, lỗi máy và bằng chứng."
          }
        }
      }
    },
