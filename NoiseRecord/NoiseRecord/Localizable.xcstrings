    "silenceReport.disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا التقرير لأغراض معلوماتية فقط وليس قياسًا قانونيًا أو بيئيًا معتمدًا."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Този отчет е само за информационни цели и не е сертифицирано правно или екологично измерване."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquest informe només té finalitats informatives i no és una mesura legal o ambiental certificada."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tato zpráva slouží pouze pro informační účely a není certifikovaným právním nebo environmentálním měřením."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne rapport er kun til informationsformål og er ikke en certificeret juridisk eller miljømæssig måling."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Bericht dient nur zu Informationszwecken und ist keine zertifizierte gesetzliche oder umweltbezogene Messung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η αναφορά είναι μόνο για ενημερωτικούς σκοπούς και δεν αποτελεί πιστοποιημένη νομική ή περιβαλλοντική μέτρηση."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This report is for informational purposes only and is not a certified legal or environmental measurement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este informe es solo informativo y no constituye una medición certificada legal o ambiental."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä raportti on tarkoitettu vain tiedoksi, eikä se ole sertifioitu laki- tai ympäristömittaus."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce rapport est informatif uniquement et ne constitue pas une mesure certifiée légale ou environnementale."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "דוח זה מיועד למטרות מידע בלבד ואינו מדידה משפטית או סביבתית מאושרת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह रिपोर्ट केवल जानकारी के लिए है; प्रमाणित कानूनी/पर्यावरण माप नहीं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovo izvješće služi samo u informativne svrhe i nije certificirano pravno ili ekološko mjerenje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a jelentés csak tájékoztató jellegű, és nem hiteles jogi vagy környezetvédelmi mérés."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan ini hanya untuk tujuan informasi dan bukan merupakan pengukuran hukum atau lingkungan yang bersertifikat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rapporto è solo a scopo informativo e non è una misurazione legale o ambientale certificata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このレポートは情報提供のみを目的としており、認定された法的測定または環境測定ではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보고서는 정보 제공 목적으로만 제공되며 인증된 법적 또는 환경적 측정이 아닙니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan ini adalah untuk tujuan maklumat sahaja dan bukan ukuran undang-undang atau persekitaran yang diperakui."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne rapporten er kun til informasjonsformål og er ikke en sertifisert juridisk eller miljømessig måling."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit rapport is uitsluitend bedoeld ter informatie en is geen gecertificeerde wettelijke of milieumeting."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niniejszy raport służy wyłącznie celom informacyjnym i nie stanowi certyfikowanego pomiaru prawnego ani środowiskowego."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este relatório é apenas informativo e não é uma medição legal ou ambiental certificada."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acest raport are doar scop informativ și nu este o măsurătoare legală sau de mediu certificată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отчёт носит информационный характер и не является сертифицированным юридическим или экологическим измерением."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Táto správa slúži len na informačné účely a nie je certifikovaným právnym alebo environmentálnym meraním."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna rapport är endast avsedd för informationsändamål och är inte en certifierad laglig eller miljömässig mätning."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายงานนี้มีวัตถุประสงค์เพื่อให้ข้อมูลเท่านั้น และไม่ใช่การวัดผลทางกฎหมายหรือสิ่งแวดล้อมที่ได้รับการรับรอง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu rapor yalnızca bilgilendirme amaçlıdır ve onaylı bir yasal veya çevresel ölçüm değildir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей звіт призначено лише для інформаційних цілей і не є сертифікованим юридичним або екологічним вимірюванням."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Báo cáo này chỉ nhằm mục đích cung cấp thông tin và không phải là thước đo pháp lý hoặc môi trường được chứng nhận."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本报告仅供参考，不构成具有法律或环境认证效力的测量结果。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本報告僅供參考，不構成具有法律或環境認證效力的測量結果。"
          }
        }
      }
    },
