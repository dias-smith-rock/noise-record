    "gauge.highSensitivity.hint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قراءات الحساسية العالية غالبًا أعلى مما تدركه."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Показанията при висока чувствителност често са по-високи, отколкото възприемате."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Les lectures d'alta sensibilitat solen ser més altes del que percebeu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hodnoty s vysokou citlivostí jsou často vyšší, než vnímáte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Højfølsomhedsmålinger er ofte højere, end du opfatter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hochempfindliche Messwerte sind oft höher, als Sie wahrnehmen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι μετρήσεις υψηλής ευαισθησίας είναι συχνά υψηλότερες από ό, τι αντιλαμβάνεστε."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High-sensitivity readings are often higher than you perceive."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las lecturas de alta sensibilidad suelen ser más altas de lo que percibes."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Korkean herkkyyden lukemat ovat usein korkeampia kuin ymmärrät."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mesures haute sensibilité sont souvent plus hautes que perçu."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קריאות ברגישות גבוהה הן לרוב גבוהות ממה שאתה תופס."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उच्च-संवेदनशीलता रीडिंग अक्सर अनुभव से अधिक होती हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Visokoosjetljiva očitanja često su veća nego što percipirate."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A nagy érzékenységű értékek gyakran magasabbak, mint amennyit észlel."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembacaan sensitivitas tinggi seringkali lebih tinggi dari yang Anda rasakan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le letture ad alta sensibilità sono spesso più elevate di quanto percepisci."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高感度の測定値は、多くの場合、あなたが認識しているよりも高くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고감도 판독값은 인식하는 것보다 더 높은 경우가 많습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bacaan kepekaan tinggi selalunya lebih tinggi daripada yang anda fikirkan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Høysensitive målinger er ofte høyere enn du oppfatter."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hooggevoelige metingen zijn vaak hoger dan u waarneemt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczyty o wysokiej czułości są często wyższe, niż się wydaje."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Leituras de alta sensibilidade costumam ser maiores do que você percebe."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Citirile de înaltă sensibilitate sunt adesea mai mari decât percepeți."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показания высокой чувствительности часто выше субъективного восприятия."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Hodnoty s vysokou citlivosťou sú často vyššie, ako vnímate."
          }
