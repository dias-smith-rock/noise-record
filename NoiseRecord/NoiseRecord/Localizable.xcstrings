    "settings.removeAds.alert.cancelled.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Покупката не е завършена. Ако вече притежавате този артикул, опитайте да възстановите покупките."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La compra no es va completar. Si ja sou el propietari d'aquest article, proveu de restaurar les compres."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nákup nebyl dokončen. Pokud již tuto položku vlastníte, zkuste Obnovit nákupy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Købet blev ikke gennemført. Hvis du allerede ejer denne vare, kan du prøve Gendan køb."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kauf wurde nicht abgeschlossen. Wenn Sie diesen Artikel bereits besitzen, versuchen Sie es mit „Käufe wiederherstellen“."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αγορά δεν ολοκληρώθηκε. Εάν έχετε ήδη αυτό το στοιχείο, δοκιμάστε την Επαναφορά αγορών."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ostoa ei suoritettu loppuun. Jos omistat jo tämän tuotteen, kokeile Palauta ostokset."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הרכישה לא הושלמה. אם כבר בבעלותך פריט זה, נסה לשחזר רכישות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kupnja nije izvršena. Ako već posjedujete ovu stavku, pokušajte vratiti kupnje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A vásárlás nem fejeződött be. Ha már a tulajdonosa ennek az elemnek, próbálja meg a Vásárlások visszaállítását."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembelian belum selesai. Jika Anda sudah memiliki item ini, coba Pulihkan Pembelian."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'acquisto non è stato completato. Se possiedi già questo articolo, prova a ripristinare gli acquisti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入は完了していません。このアイテムをすでに所有している場合は、購入を復元してみてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구매가 완료되지 않았습니다. 이 항목을 이미 소유하고 있다면 구매 복원을 시도해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembelian tidak selesai. Jika anda sudah memiliki item ini, cuba Pulihkan Pembelian."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kjøpet ble ikke gjennomført. Hvis du allerede eier denne varen, prøv Gjenopprett kjøp."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De aankoop is niet voltooid. Als je dit item al bezit, probeer dan Aankopen herstellen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zakup nie został sfinalizowany. Jeśli już posiadasz ten przedmiot, spróbuj przywrócić zakupy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Achiziția nu a fost finalizată. Dacă dețineți deja acest articol, încercați Restaurare achiziții."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase was not completed. If you already own this item, try Restore Purchases."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nákup nebol dokončený. Ak už túto položku vlastníte, skúste Obnoviť nákupy."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Köpet slutfördes inte. Om du redan äger det här objektet, prova Återställ köp."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การซื้อไม่เสร็จสมบูรณ์ หากคุณเป็นเจ้าของรายการนี้แล้ว ให้ลองกู้คืนการซื้อ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Satın alma işlemi tamamlanmadı. Bu öğeye zaten sahipseniz Satın Alınanları Geri Yüklemeyi deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Закупівля не завершена. Якщо ви вже володієте цим предметом, спробуйте відновити покупки."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Việc mua hàng chưa hoàn tất. Nếu bạn đã sở hữu mặt hàng này, hãy thử Khôi phục các giao dịch mua."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买未完成。若您已购买过，请尝试「恢复购买」。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "購買未完成。若您已購買過，請嘗試「恢復購買」。"
          }
        }
      }
