    "settings.calibration.reset.alert.restored.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم مسح تعديلك اليدوي (%1$@).\n\nإجمالي الإزاحة: %2$@ → %3$@\nتعديل المستخدم: %4$@ → 0 dB\n\nتعود القراءات إلى الإعداد الافتراضي. أعد المعايرة بمقياس عند الحاجة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cleared your manual adjustment (%1$@).\n\nTotal offset: %2$@ → %3$@\nUser adjustment: %4$@ → 0 dB\n\nMonitor readings return to factory defaults. Recalibrate with a meter if needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminó tu ajuste manual (%1$@).\n\nOffset total: %2$@ → %3$@\nAjuste del usuario: %4$@ → 0 dB\n\nLas lecturas vuelven a valores de fábrica. Recalibra con un medidor si hace falta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre ajustement manuel (%1$@) a été effacé.\n\nOffset total : %2$@ → %3$@\nAjustement utilisateur : %4$@ → 0 dB\n\nLes mesures reviennent aux réglages d’usine. Réétalonnez si besoin."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका मैनुअल समायोजन (%1$@) हटाया गया।\n\nकुल ऑफ़सेट: %2$@ → %3$@\nउपयोगकर्ता समायोजन: %4$@ → 0 dB\n\nरीडिंग फ़ैक्टरी डिफ़ॉल्ट पर लौटती हैं। ज़रूरत हो तो मीटर से फिर कैलिब्रेट करें।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu ajuste manual (%1$@) foi removido.\n\nOffset total: %2$@ → %3$@\nAjuste do usuário: %4$@ → 0 dB\n\nAs leituras voltam ao padrão de fábrica. Recalibre com um medidor se necessário."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ручная поправка (%1$@) сброшена.\n\nСуммарное смещение: %2$@ → %3$@\nПользовательская поправка: %4$@ → 0 dB\n\nПоказания возвращаются к заводским. При необходимости откалибруйте снова."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已清除手动调整（%1$@）。\n\n总偏移：%2$@ → %3$@\n用户调整：%4$@ → 0 dB\n\n监测读数恢复出厂默认。如有需要请重新校准。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已清除手動調整（%1$@）。\n\n總偏移：%2$@ → %3$@\n使用者調整：%4$@ → 0 dB\n\n監測讀數恢復出廠預設。如有需要請重新校準。"
          }
        }
      }
    },
