    "settings.disclaimer.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro uses your iPhone microphone and is not a certified sound level meter. Readings are estimates for personal reference and evidence documentation only."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro 使用手机麦克风，并非认证声级计。读数仅供个人参考与取证记录，不构成专业测量结果。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro 使用手機麥克風，並非認證聲級計。讀數僅供個人參考與取證記錄，不構成專業測量結果。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro използва микрофона на вашия iPhone и не е сертифициран шумомер. Показанията са приблизителни само за лична справка и доказателствена документация."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro utilitza el micròfon del vostre iPhone i no és un sonòmetre certificat. Les lectures són estimacions només per a referència personal i documentació de proves."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro používá mikrofon vašeho iPhone a není certifikovaným měřičem hladiny zvuku. Hodnoty jsou odhady pouze pro osobní referenci a důkazní dokumentaci."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro bruger din iPhone-mikrofon og er ikke en certificeret lydniveaumåler. Aflæsninger er kun skøn til personlig reference og dokumentation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro verwendet Ihr iPhone-Mikrofon und ist kein zertifizierter Schallpegelmesser. Bei den Messwerten handelt es sich ausschließlich um Schätzungen zur persönlichen Referenz und Beweisdokumentation."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το DecibelPro χρησιμοποιεί το μικρόφωνό σας iPhone και δεν είναι πιστοποιημένο μετρητή στάθμης ήχου. Οι αναγνώσεις είναι εκτιμήσεις μόνο για προσωπική αναφορά και τεκμηρίωση αποδεικτικών στοιχείων."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro käyttää iPhone-mikrofoniasi, eikä se ole sertifioitu äänitasomittari. Lukemat ovat arvioita vain henkilökohtaiseksi viitteeksi ja todisteeksi."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro משתמש במיקרופון האייפון שלך ואינו מד רמת קול מוסמך. קריאות הן הערכות לעיון אישי ותיעוד ראיות בלבד."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro koristi vaš iPhone mikrofon i nije certificirani mjerač razine zvuka. Očitavanja su procjene samo za osobnu referencu i dokumentaciju dokaza."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A DecibelPro az Ön iPhone mikrofonját használja, és nem hitelesített hangszintmérő. A leolvasott adatok becslések, csak személyes referenciaként és bizonyítékként szolgálnak."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro menggunakan mikrofon iPhone Anda dan bukan pengukur tingkat suara bersertifikat. Pembacaan hanyalah perkiraan untuk referensi pribadi dan dokumentasi bukti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro utilizza il microfono del tuo iPhone e non è un fonometro certificato. Le letture sono stime solo per riferimento personale e documentazione di prova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro は iPhone のマイクを使用しており、認定された騒音計ではありません。測定値は、個人的な参考および証拠文書としてのみ使用される推定値です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro은(는) iPhone 마이크를 사용하며 인증된 소음 측정기가 아닙니다. 판독값은 개인적인 참조 및 증거 문서용으로만 추정됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro menggunakan mikrofon iPhone anda dan bukan meter aras bunyi yang diperakui. Bacaan adalah anggaran untuk rujukan peribadi dan dokumentasi bukti sahaja."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro bruker iPhone-mikrofonen din og er ikke en sertifisert lydnivåmåler. Avlesninger er kun anslag for personlig referanse og bevisdokumentasjon."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro gebruikt de microfoon van uw iPhone en is geen gecertificeerde geluidsniveaumeter. De meetwaarden zijn uitsluitend schattingen voor persoonlijke referentie en bewijsdocumentatie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro korzysta z mikrofonu Twojego iPhone'a i nie jest certyfikowanym miernikiem poziomu dźwięku. Odczyty mają charakter szacunkowy i służą wyłącznie do celów osobistych i do celów dokumentacji dowodowej."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro folosește microfonul iPhone-ului și nu este un sonometru certificat. Citirile sunt estimări doar pentru referință personală și documentație de dovezi."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro používa váš mikrofón iPhone a nie je certifikovaným zvukomerom. Hodnoty sú odhady len pre osobnú referenciu a dôkazovú dokumentáciu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro använder din iPhone-mikrofon och är inte en certifierad ljudnivåmätare. Avläsningar är uppskattningar endast för personlig referens och bevisdokumentation."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro ใช้ไมโครโฟน iPhone ของคุณและไม่ใช่เครื่องวัดระดับเสียงที่ได้รับการรับรอง การอ่านเป็นการประมาณการสำหรับการอ้างอิงส่วนบุคคลและเอกสารหลักฐานเท่านั้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro iPhone mikrofonunuzu kullanır ve sertifikalı bir ses seviyesi ölçer değildir. Okumalar yalnızca kişisel referans ve kanıt belgeleri için yapılan tahminlerdir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro використовує мікрофон вашого iPhone і не є сертифікованим шумоміром. Показання є приблизними лише для особистої довідки та доказової документації."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro sử dụng micrô iPhone của bạn và không phải là máy đo mức âm thanh được chứng nhận. Bài đọc chỉ là ước tính để tham khảo cá nhân và tài liệu bằng chứng."
          }
        }
      }
    },
