    "settings.review.prompt.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Your review helps others find a reliable noise evidence tool. Tell us what works for you on the App Store — a few words about your experience means a lot."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的评论能帮助更多人找到可靠的噪声取证工具。欢迎在 App Store 写下使用感受，哪怕几句话也很有价值。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的評論能幫助更多人找到可靠的噪聲取證工具。歡迎在 App Store 寫下使用感受，哪怕幾句話也很有價值。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Вашият преглед помага на другите да намерят надежден инструмент за доказване на шума. Кажете ни какво работи за вас в App Store — няколко думи за вашия опит означават много."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva ressenya ajuda els altres a trobar una eina fiable de proves de soroll. Expliqueu-nos què us funciona a l'App Store: unes poques paraules sobre la vostra experiència signifiquen molt."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše recenze pomáhá ostatním najít spolehlivý nástroj pro evidenci hluku. Řekněte nám, co vám v App Store vyhovuje – pár slov o vašich zkušenostech znamená hodně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din anmeldelse hjælper andre med at finde et pålideligt støjbevisværktøj. Fortæl os, hvad der virker for dig i App Store - et par ord om din oplevelse betyder meget."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Bewertung hilft anderen, ein zuverlässiges Tool zum Nachweis von Lärm zu finden. Sagen Sie uns im App Store, was für Sie funktioniert – ein paar Worte über Ihre Erfahrungen bedeuten viel."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η κριτική σας βοηθά άλλους να βρουν ένα αξιόπιστο εργαλείο αποδεικτικών στοιχείων θορύβου. Πείτε μας τι λειτουργεί για εσάς στο App Store — λίγα λόγια για την εμπειρία σας σημαίνουν πολλά."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Arvostelusi auttaa muita löytämään luotettavan melun näyttötyökalun. Kerro meille, mikä toimii sinulle App Storessa – muutama sana kokemuksestasi merkitsee paljon."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הסקירה שלך עוזרת לאחרים למצוא כלי אמין להוכחת רעש. ספר לנו מה עובד בשבילך ב-App Store - כמה מילים על החוויה שלך אומרות הרבה."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša recenzija pomaže drugima da pronađu pouzdan alat za dokaz buke. Recite nam što vam odgovara na App Storeu — nekoliko riječi o vašem iskustvu puno znači."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Ön véleménye segít másoknak megbízható zajbizonyító eszközt találni. Mondja el, mi működik az Ön számára az App Store-ban – néhány szó a tapasztalatairól sokat jelent."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ulasan Anda membantu orang lain menemukan alat bukti kebisingan yang andal. Beri tahu kami apa yang cocok untuk Anda di App Store — beberapa kata tentang pengalaman Anda sangat berarti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua recensione aiuta gli altri a trovare uno strumento affidabile per la prova del rumore. Raccontaci cosa funziona per te sull'App Store: poche parole sulla tua esperienza significano molto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのレビューは、他の人が信頼できる騒音証拠ツールを見つけるのに役立ちます。 App Store で何があなたにとって効果的かを教えてください。あなたの経験についての一言が大きな意味を持ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "귀하의 리뷰는 다른 사람들이 신뢰할 수 있는 소음 증거 도구를 찾는 데 도움이 됩니다. App Store에서 귀하에게 적합한 것이 무엇인지 알려주세요. 귀하의 경험에 대한 몇 마디 말은 많은 의미를 갖습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ulasan anda membantu orang lain mencari alat bukti bunyi yang boleh dipercayai. Beritahu kami perkara yang sesuai untuk anda di App Store — beberapa perkataan tentang pengalaman anda amat bermakna."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Din anmeldelse hjelper andre med å finne et pålitelig verktøy for støybevis. Fortell oss hva som fungerer for deg på App Store – noen få ord om opplevelsen din betyr mye."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jouw beoordeling helpt anderen een betrouwbaar hulpmiddel voor geluidsbewijs te vinden. Vertel ons wat voor u werkt in de App Store. Een paar woorden over uw ervaring betekenen veel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoja recenzja pomoże innym znaleźć wiarygodne narzędzie do badania hałasu. Powiedz nam, co sprawdza się w przypadku App Store — kilka słów o Twoim doświadczeniu wiele znaczy."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Recenzia dvs. îi ajută pe alții să găsească un instrument de încredere pentru evidența zgomotului. Spune-ne ce funcționează pentru tine în App Store — câteva cuvinte despre experiența ta înseamnă foarte mult."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša recenzia pomáha ostatným nájsť spoľahlivý nástroj na evidenciu hluku. Povedzte nám, čo vám v App Store vyhovuje – pár slov o vašej skúsenosti znamená veľa."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din recension hjälper andra att hitta ett tillförlitligt verktyg för bullerbevis. Berätta för oss vad som fungerar för dig i App Store – några ord om din upplevelse betyder mycket."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บทวิจารณ์ของคุณช่วยให้ผู้อื่นค้นพบเครื่องมือหลักฐานทางเสียงที่เชื่อถือได้ บอกเราว่าอะไรที่เหมาะกับคุณใน App Store คำไม่กี่คำเกี่ยวกับประสบการณ์ของคุณมีความหมายมาก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İncelemeniz başkalarının güvenilir bir gürültü kanıt aracı bulmasına yardımcı olur. Bize App Store'da sizin için neyin işe yaradığını söyleyin; deneyiminiz hakkında birkaç kelime çok şey ifade ediyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш відгук допоможе іншим знайти надійний інструмент доказів шуму. Розкажіть нам, що вам підходить в App Store — кілька слів про ваш досвід значать багато."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đánh giá của bạn giúp người khác tìm thấy công cụ chống ồn đáng tin cậy. Hãy cho chúng tôi biết điều gì phù hợp với bạn trên App Store - một vài lời về trải nghiệm của bạn có ý nghĩa rất lớn."
          }
        }
      }
    },
