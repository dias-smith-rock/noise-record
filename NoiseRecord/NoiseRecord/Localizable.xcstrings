    "recorderSettings.aiFilter.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احتفظ فقط بالمقاطع المطابقة للأنواع المحددة."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Запазете само клипове, които отговарят на избрани типове звук."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserveu només els clips que coincideixin amb els tipus de so seleccionats."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uchovávejte pouze klipy, které odpovídají vybraným typům zvuku."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gem kun klip, der matcher udvalgte lydtyper."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalten Sie nur Clips, die den ausgewählten Soundtypen entsprechen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διατηρήστε μόνο κλιπ που ταιριάζουν με επιλεγμένους τύπους ήχου."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only keep clips that match selected sound types."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserva solo clips que coincidan con los tipos seleccionados."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Säilytä vain leikkeet, jotka vastaavat valittuja äänityyppejä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne conserve que les clips correspondant aux types choisis."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שמור רק קליפים התואמים סוגי סאונד נבחרים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल चुने ध्वनि प्रकार के क्लिप रखें।"
