    "permission.microphone.denied.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro 需要麦克风权限以测量噪声并录音。请在设置中开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro 需要麥克風權限以測量噪聲並錄音。請在設定中開啟。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro се нуждае от достъп до микрофона, за да измерва нивата на звука и да записва аудио. Активирайте го в Настройки."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro necessita accés al micròfon per mesurar els nivells de so i gravar àudio. Activeu-lo a Configuració."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro potřebuje přístup k mikrofonu, aby mohl měřit úrovně zvuku a nahrávat zvuk. Povolte jej v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro har brug for mikrofonadgang for at måle lydniveauer og optage lyd. Aktiver det i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro benötigt Zugriff auf das Mikrofon, um Schallpegel zu messen und Audio aufzunehmen. Aktivieren Sie es in den Einstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το DecibelPro χρειάζεται πρόσβαση στο μικρόφωνο για τη μέτρηση των επιπέδων ήχου και την εγγραφή ήχου. Ενεργοποιήστε το στις Ρυθμίσεις."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro tarvitsee mikrofonin pääsyn äänitason mittaamiseen ja äänen tallentamiseen. Ota se käyttöön asetuksista."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro זקוק לגישה למיקרופון כדי למדוד רמות קול ולהקליט אודיו. הפעל את זה בהגדרות."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro treba pristup mikrofonu za mjerenje razine zvuka i snimanje zvuka. Omogućite ga u postavkama."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A DecibelPro mikrofon-hozzáférést igényel a hangszint méréséhez és a hang rögzítéséhez. Engedélyezze a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro memerlukan akses mikrofon untuk mengukur level suara dan merekam audio. Aktifkan di Pengaturan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro necessita dell'accesso al microfono per misurare i livelli sonori e registrare l'audio. Abilitalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro では、騒音レベルの測定と音声の録音のためにマイクへのアクセスが必要です。設定で有効にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro은 소음 수준을 측정하고 오디오를 녹음하려면 마이크 액세스 권한이 필요합니다. 설정에서 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro memerlukan akses mikrofon untuk mengukur tahap bunyi dan merakam audio. Dayakannya dalam Tetapan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro trenger mikrofontilgang for å måle lydnivåer og ta opp lyd. Aktiver det i Innstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro heeft microfoontoegang nodig om het geluidsniveau te meten en audio op te nemen. Schakel het in Instellingen in."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro potrzebuje dostępu do mikrofonu, aby mierzyć poziom dźwięku i nagrywać dźwięk. Włącz to w Ustawieniach."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro are nevoie de acces la microfon pentru a măsura nivelurile de sunet și pentru a înregistra sunet. Activați-l în Setări."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro potrebuje prístup k mikrofónu na meranie úrovní zvuku a nahrávanie zvuku. Povoľte ho v Nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro behöver mikrofonåtkomst för att mäta ljudnivåer och spela in ljud. Aktivera det i Inställningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro ต้องการเข้าถึงไมโครโฟนเพื่อวัดระดับเสียงและบันทึกเสียง เปิดใช้งานได้ในการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro'nin ses seviyelerini ölçmek ve ses kaydetmek için mikrofon erişimine ihtiyacı var. Ayarlar'da etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro потребує доступу до мікрофона, щоб вимірювати рівні звуку та записувати звук. Увімкніть це в налаштуваннях."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "DecibelPro cần quyền truy cập vào micrô để đo mức âm thanh và ghi lại âm thanh. Kích hoạt nó trong Cài đặt."
          }
        }
      }
    },
    "permission.microphone.denied.title": {
      "extractionState": "manual",
      "localizations": {
