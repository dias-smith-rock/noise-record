          "stringUnit": {
            "state": "translated",
            "value": "Monitorování hluku probíhá automaticky během nahrávání."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Støjovervågning kører automatisk under optagelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Geräuschüberwachung läuft automatisch während der Aufnahme."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η παρακολούθηση θορύβου εκτελείται αυτόματα κατά την εγγραφή."
