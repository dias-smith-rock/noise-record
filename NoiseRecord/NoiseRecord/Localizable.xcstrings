        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue medindo o ruído em outras abas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжайте измерять шум в других вкладках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用其他标签页时继续测量噪声。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用其他標籤時繼續測量噪音。"
