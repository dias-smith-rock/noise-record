    "permission.camera.denied.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "За видео доказателства е необходим достъп до камерата. Активирайте го в Настройки."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accés a la càmera és necessari per a proves de vídeo. Activeu-lo a Configuració."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro důkaz videa je vyžadován přístup k fotoaparátu. Povolte jej v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameraadgang er påkrævet for videobevis. Aktiver det i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für den Videobeweis ist der Zugriff auf die Kamera erforderlich. Aktivieren Sie es in den Einstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απαιτείται πρόσβαση στην κάμερα για τεκμήρια βίντεο. Ενεργοποιήστε το στις Ρυθμίσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Videotodistusta varten tarvitaan pääsy kameraan. Ota se käyttöön asetuksista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נדרשת גישה למצלמה עבור ראיות וידאו. הפעל את זה בהגדרות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Za videodokaz potreban je pristup kameri. Omogućite ga u postavkama."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A videobizonyításhoz kamera-hozzáférés szükséges. Engedélyezze a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera diperlukan untuk bukti video. Aktifkan di Pengaturan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per le prove video è necessario l'accesso alla telecamera. Abilitalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビデオ証拠を得るにはカメラへのアクセスが必要です。設定で有効にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "영상 증거를 위해 카메라 접근이 필요합니다. 설정에서 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses kamera diperlukan untuk bukti video. Dayakannya dalam Tetapan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameratilgang er nødvendig for videobevis. Aktiver det i Innstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voor videobewijs is cameratoegang vereist. Schakel het in Instellingen in."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby uzyskać dowód wideo, wymagany jest dostęp do kamery. Włącz to w Ustawieniach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesul la cameră este necesar pentru dovezile video. Activați-l în Setări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera access is required for video evidence. Enable it in Settings."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pre video dôkaz je potrebný prístup k fotoaparátu. Povoľte ho v Nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kameraåtkomst krävs för videobevis. Aktivera det i Inställningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จำเป็นต้องมีการเข้าถึงกล้องเพื่อเป็นหลักฐานวิดีโอ เปิดใช้งานได้ในการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Video kanıtı için kamera erişimi gereklidir. Ayarlar'da etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Для відеозапису потрібен доступ до камери. Увімкніть це в налаштуваннях."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần có quyền truy cập vào máy ảnh để có bằng chứng video. Kích hoạt nó trong Cài đặt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "录像取证需要相机权限。请在设置中开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錄影取證需要相機權限。請在設定中開啟。"
          }
        }
      }
    },
