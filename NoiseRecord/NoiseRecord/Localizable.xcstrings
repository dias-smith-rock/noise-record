    "silenceGrade.b.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هادئ عمومًا مع إزعاج طفيف أحيانًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generally quiet with occasional minor disturbances."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En general silencioso con molestias menores ocasionales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Globalement calme avec de rares nuisances mineures."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सामान्यतः शांत, कभी-कभी हल्की व्यवधान।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Em geral silencioso com perturbações leves ocasionais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В целом тихо, изредка незначительные помехи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "总体安静，偶有轻微干扰。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "總體安靜，偶有輕微干擾。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Като цяло тихо със случайни незначителни смущения."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Generalment tranquil amb petites molèsties ocasionals."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Obecně klid s občasnými menšími poruchami."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Generelt stille med lejlighedsvise mindre forstyrrelser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Allgemeinen ruhig mit gelegentlichen kleineren Störungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Γενικά ησυχία με περιστασιακές μικρές αναταραχές."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yleensä hiljaista, joskus pieniä häiriöitä."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שקט בדרך כלל עם הפרעות קלות מדי פעם."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Općenito tiho uz povremene manje smetnje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Általában csendes, időnként kisebb zavarokkal."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Umumnya tenang dengan gangguan kecil sesekali."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Generalmente tranquillo con occasionali disturbi minori."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "全体的に静かですが、時折小さな騒音が発生します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가끔 사소한 소란이 있을 수 있지만 일반적으로 조용합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Secara umumnya senyap dengan gangguan kecil sekali-sekala."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Generelt stille med sporadiske mindre forstyrrelser."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Over het algemeen rustig met af en toe kleine verstoringen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogólnie cicho, sporadycznie zdarzają się drobne zakłócenia."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "În general, liniște, cu mici neplăceri ocazionale."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vo všeobecnosti ticho s občasnými menšími poruchami."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Generellt tyst med enstaka mindre störningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โดยทั่วไปจะเงียบสงบและมีเสียงรบกวนเล็กน้อยเป็นบางครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ara sıra ufak rahatsızlıklar yaşansa da genel olarak sessizdir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Загалом тихо, час від часу незначні незручності."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nói chung yên tĩnh, thỉnh thoảng có tiếng ồn nhỏ."
          }
        }
      }
    },
