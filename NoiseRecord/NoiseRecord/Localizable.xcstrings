    "mode.highSensitivity.comparisonHint" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "القراءات غالبًا أعلى من الوضع القياسي—هذا طبيعي؛ يقيس صوتًا قد لا تسمعه لكنه موجود."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Readings are often higher than standard mode—that is normal; it measures sound you may not hear but is still there."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las lecturas suelen ser más altas que en modo estándar—es normal; mide sonido que quizá no oyes pero está ahí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les mesures sont souvent plus hautes qu’en standard—c’est normal ; elles mesurent du son inaudible mais présent."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "रीडिंग अक्सर मानक से अधिक—यह सामान्य है; ऐसी ध्वनि मापता है जो सुनाई न दे पर मौजूद हो।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As leituras costumam ser maiores que no modo padrão—é normal; mede som que você talvez não ouça, mas está lá."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Показания часто выше стандартного режима—это нормально; измеряется звук, который вы можете не слышать."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "读数常高于标准模式——属正常；它测量您可能听不见但仍存在的声音。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "讀數常高於標準模式——屬正常；它測量您可能聽不見但仍存在的聲音。"
          }
        }
      }
    },
    "mode.highSensitivity.coreDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعطّل مرشحات السمع وقمع ضوضاء النظام لالتقاط طاقة الصوت الفيزيائية كاملة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disables hearing-weighted filters and system noise suppression to capture full physical sound energy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desactiva filtros de audición y supresión de ruido del sistema para captar toda la energía sonora física."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désactive les filtres d’audition et la suppression système pour capturer toute l’énergie acoustique physique."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "श्रवण-भारित फ़िल्टर और सिस्टम शोर दमन बंद कर पूर्ण भौतिक ध्वनि ऊर्जा पकड़ता है।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desativa filtros de audição e supressão de ruído do sistema para capturar toda a energia sonora física."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отключает слуховые фильтры и подавление шума системы для полной физической энергии звука."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭听感计权滤波与系统降噪，以捕捉完整物理声能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "關閉聽感計權濾波與系統降噪，以捕捉完整物理聲能。"
          }
        }
      }
    },
