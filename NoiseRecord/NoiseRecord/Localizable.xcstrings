    "video.hint.autoMonitoring": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعمل مراقبة الضوضاء تلقائيًا أثناء التسجيل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Noise monitoring runs automatically while recording."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La monitorización de ruido se ejecuta automáticamente al grabar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La surveillance du bruit démarre automatiquement pendant l’enregistrement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्डिंग के दौरान शोर मॉनिटरिंग स्वचालित चलती है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O monitoramento de ruído roda automaticamente durante a gravação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мониторинг шума включается автоматически при записи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "录制时自动进行噪声监测。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錄製時自動進行噪音監測。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Наблюдението на шума работи автоматично по време на запис."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El control del soroll s'executa automàticament durant la gravació."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorování hluku probíhá automaticky během nahrávání."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Støjovervågning kører automatisk under optagelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Geräuschüberwachung läuft automatisch während der Aufnahme."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η παρακολούθηση θορύβου εκτελείται αυτόματα κατά την εγγραφή."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Melunvalvonta toimii automaattisesti tallennuksen aikana."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ניטור הרעש פועל אוטומטית בזמן ההקלטה."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Praćenje buke radi automatski tijekom snimanja."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A zajfigyelés automatikusan fut rögzítés közben."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemantauan kebisingan berjalan secara otomatis saat merekam."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il monitoraggio del rumore viene eseguito automaticamente durante la registrazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音中にノイズモニタリングが自動的に実行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음하는 동안 소음 모니터링이 자동으로 실행됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemantauan bunyi berjalan secara automatik semasa merakam."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Støyovervåking kjører automatisk under opptak."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruismonitoring wordt automatisch uitgevoerd tijdens het opnemen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorowanie hałasu działa automatycznie podczas nagrywania."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorizarea zgomotului rulează automat în timpul înregistrării."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorovanie hluku beží automaticky počas nahrávania."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Brusövervakning körs automatiskt under inspelning."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การตรวจสอบเสียงรบกวนจะทำงานโดยอัตโนมัติขณะบันทึก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
