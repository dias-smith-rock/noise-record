    "recorderSettings.backgroundMonitoring.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استمر في قياس الضوضاء أثناء استخدام علامات أخرى."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Продължете да измервате шума, докато използвате други раздели."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Continueu mesurant el soroll mentre feu servir altres pestanyes."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokračujte v měření hluku při používání jiných karet."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bliv ved med at måle støj, mens du bruger andre faner."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Messen Sie den Lärm weiter, während Sie andere Registerkarten verwenden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Συνεχίστε να μετράτε τον θόρυβο ενώ χρησιμοποιείτε άλλες καρτέλες."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep measuring noise while using other tabs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue midiendo el ruido mientras usas otras pestañas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jatka melun mittaamista käyttäessäsi muita välilehtiä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue de mesurer le bruit dans les autres onglets."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המשך למדוד רעש תוך כדי שימוש בלשוניות אחרות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अन्य टैब पर भी शोर मापते रहें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavite mjeriti buku dok koristite druge kartice."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Más fülek használata közben folytassa a zaj mérését."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terus ukur kebisingan saat menggunakan tab lain."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Continua a misurare il rumore mentre usi altre schede."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のタブを使用している間もノイズを測定し続けます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 탭을 사용하는 동안 계속해서 소음을 측정하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Teruskan mengukur hingar semasa menggunakan tab lain."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fortsett å måle støy mens du bruker andre faner."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blijf het geluid meten terwijl u andere tabbladen gebruikt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontynuuj pomiar hałasu, korzystając z innych zakładek."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue medindo o ruído em outras abas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuați să măsurați zgomotul în timp ce utilizați alte file."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжайте измерять шум в других вкладках."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Počas používania iných kariet pokračujte v meraní hluku."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Fortsätt att mäta buller medan du använder andra flikar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วัดเสียงรบกวนต่อไปขณะใช้แท็บอื่น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Diğer sekmeleri kullanırken gürültüyü ölçmeye devam edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Продовжуйте вимірювати шум, використовуючи інші вкладки."
