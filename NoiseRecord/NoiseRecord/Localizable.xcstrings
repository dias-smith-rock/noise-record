            "state": "translated",
            "value": "बिजली बचाने के लिए सिस्टम ने निगरानी रोक दी।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sustav je pauzirao nadzor radi uštede energije."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A rendszer szünetelteti a megfigyelést az energiatakarékosság érdekében."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem menghentikan sementara pemantauan untuk menghemat daya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema ha sospeso il monitoraggio per risparmiare energia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "電力を節約するためにシステムは監視を一時停止しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전력을 절약하기 위해 시스템이 모니터링을 일시 중지했습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem menjeda pemantauan untuk menjimatkan kuasa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet stoppet overvåkingen midlertidig for å spare strøm."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het systeem heeft de monitoring onderbroken om energie te besparen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "System wstrzymał monitorowanie, aby oszczędzać energię."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema pausou o monitoramento para economizar energia."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemul a întrerupt monitorizarea pentru a economisi energie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Система приостановила мониторинг для экономии энергии."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém pozastavil monitorovanie, aby šetril energiu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet pausade övervakningen för att spara ström."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ระบบหยุดการตรวจสอบชั่วคราวเพื่อประหยัดพลังงาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem güçten tasarruf etmek için izlemeyi duraklattı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Система призупинила моніторинг для економії енергії."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hệ thống tạm dừng giám sát để tiết kiệm điện."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统为省电已暂停监测。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統為省電已暫停監測。"
          }
        }
      }
    },
