    "mode.standard.comparisonHint" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "القراءات تطابق مدى علو الصوت لديك—مفيدة للمقارنة بالمعايير."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Readings match how loud it sounds to you—useful for comparing against noise standards."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las lecturas coinciden con lo fuerte que suena—útil para comparar con normas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les mesures reflètent le volume ressenti—utile pour les normes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "रीडिंग आपको जितना तेज़ लगता है उसके करीब—मानक से तुलना के लिए उपयोगी।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As leituras correspondem ao que você ouve—útil para comparar com normas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Показания соответствуют субъективной громкости—удобно сравнивать с нормами."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "读数贴近您感受到的响度，便于对照噪声标准。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "讀數貼近您感受到的響度，便於對照噪音標準。"
          }
        }
      }
    },
    "mode.standard.coreDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحاكي إدراك الأذن البشرية للصوت، مع ترشيح الترددات الأقل حساسية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simulates how the human ear perceives sound, filtering frequencies we are less sensitive to."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simula cómo percibe el oído humano el sonido, filtrando frecuencias a las que somos menos sensibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simule la perception sonore de l’oreille humaine en filtrant les fréquences moins sensibles."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मानव कान की ध्वनि अनुभूति की नकल करता है, कम संवेदनशील आवृत्तियाँ छानता है।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simula como o ouvido humano percebe o som, filtrando frequências às quais somos menos sensíveis."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Имитирует восприятие звука ухом, отфильтровывая менее чувствительные частоты."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "模拟人耳对声音的感知，滤除较不敏感的频率。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "模擬人耳對聲音的感知，濾除較不敏感的頻率。"
          }
        }
      }
    },
