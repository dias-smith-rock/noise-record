        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete all stored measurement samples? This cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除所有已存储的测量样本？此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除所有已儲存的測量樣本？此操作無法撤銷。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Изтриване на всички съхранени проби от измервания? Това не може да бъде отменено."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Vols suprimir totes les mostres de mesura emmagatzemades? Això no es pot desfer."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Smazat všechny uložené vzorky měření? Toto nelze vrátit zpět."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vil du slette alle gemte måleprøver? Dette kan ikke fortrydes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle gespeicherten Messproben löschen? Dies kann nicht rückgängig gemacht werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαγραφή όλων των αποθηκευμένων δειγμάτων μέτρησης; Αυτό δεν μπορεί να αναιρεθεί."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Poistetaanko kaikki tallennetut mittausnäytteet? Tätä ei voi kumota."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "למחוק את כל דגימות המדידה המאוחסנות? לא ניתן לבטל זאת."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izbrisati sve pohranjene uzorke mjerenja? Ovo se ne može poništiti."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Törli az összes tárolt mérési mintát? Ezt nem lehet visszavonni."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus semua sampel pengukuran yang disimpan? Hal ini tidak dapat dibatalkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminare tutti i campioni di misurazione memorizzati? Questa operazione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されている測定サンプルをすべて削除しますか?これを元に戻すことはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 측정 샘플을 모두 삭제하시겠습니까? 이 작업은 취소할 수 없습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Padamkan semua sampel ukuran yang disimpan? Ini tidak boleh dibuat asal."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vil du slette alle lagrede måleprøver? Dette kan ikke angres."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle opgeslagen meetmonsters verwijderen? Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunąć wszystkie zapisane próbki pomiarowe? Tego nie można cofnąć."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ștergeți toate mostrele de măsurare stocate? Acest lucru nu poate fi anulat."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vymazať všetky uložené vzorky meraní? Toto sa nedá vrátiť späť."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort alla lagrade mätprover? Detta kan inte ångras."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบตัวอย่างการวัดที่เก็บไว้ทั้งหมดใช่ไหม สิ่งนี้ไม่สามารถยกเลิกได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saklanan tüm ölçüm örnekleri silinsin mi? Bu geri alınamaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видалити всі збережені зразки вимірювань? Це неможливо скасувати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa tất cả các mẫu đo được lưu trữ? Điều này không thể hoàn tác được."
          }
        }
      }
    },
