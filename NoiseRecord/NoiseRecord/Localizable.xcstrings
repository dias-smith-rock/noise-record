    "appReview.prompt.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ако това приложение ви помага да документирате шума, бърз преглед в App Store би означавал много."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Si aquesta aplicació us ajuda a documentar el soroll, una revisió ràpida de l'App Store significaria molt."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokud vám tato aplikace pomůže dokumentovat hluk, rychlá recenze z App Store by znamenala hodně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis denne app hjælper dig med at dokumentere støj, ville en hurtig App Store-gennemgang betyde meget."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Ihnen diese App dabei hilft, Lärm zu dokumentieren, würde eine kurze Überprüfung im App Store viel bedeuten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εάν αυτή η εφαρμογή σάς βοηθά να τεκμηριώσετε το θόρυβο, μια γρήγορη αναθεώρηση του App Store θα σήμαινε πολλά."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jos tämä sovellus auttaa dokumentoimaan melua, nopea App Store -arvostelu merkitsisi paljon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אם האפליקציה הזו עוזרת לך לתעד רעשים, סקירה מהירה של App Store תהיה בעלת משמעות רבה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ako vam ova aplikacija pomaže dokumentirati buku, brzi pregled u App Storeu puno bi značio."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha ez az alkalmazás segít a zaj dokumentálásában, az App Store gyors áttekintése sokat jelentene."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika aplikasi ini membantu Anda mendokumentasikan kebisingan, tinjauan singkat App Store akan sangat berarti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se questa app ti aiuta a documentare il rumore, una rapida revisione dell'App Store significherebbe molto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリがノイズの記録に役立つのであれば、App Store での簡単なレビューは大きな意味を持つでしょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱이 소음을 문서화하는 데 도움이 된다면 빠른 App Store 검토가 큰 의미가 있을 것입니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika apl ini membantu anda mendokumentasikan bunyi bising, semakan App Store pantas akan sangat bermakna."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis denne appen hjelper deg med å dokumentere støy, vil en rask App Store-gjennomgang bety mye."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als deze app je helpt ruis te documenteren, zou een snelle beoordeling in de App Store veel betekenen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli ta aplikacja pomoże Ci dokumentować hałas, szybka recenzja w App Store będzie miała ogromne znaczenie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dacă această aplicație vă ajută să documentați zgomotul, o revizuire rapidă a App Store ar însemna foarte mult."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "If this app helps you document noise, a quick App Store review would mean a lot."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ak vám táto aplikácia pomôže zdokumentovať šum, rýchla kontrola z App Store by znamenala veľa."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om den här appen hjälper dig att dokumentera brus skulle en snabb App Store-granskning betyda mycket."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากแอปนี้ช่วยคุณบันทึกเสียงรบกวน การตรวจสอบ App Store อย่างรวดเร็วจะมีความหมายมาก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu uygulama gürültüyü belgelemenize yardımcı olacaksa, hızlı bir App Store incelemesi çok şey ifade edecektir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо ця програма допоможе вам задокументувати шум, швидка перевірка в App Store буде дуже важливою."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu ứng dụng này giúp bạn ghi lại tiếng ồn thì việc đánh giá nhanh trên App Store sẽ có ý nghĩa rất lớn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果这款应用对你记录噪声有帮助，欢迎在 App Store 给我们评分。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果這款 App 對你記錄噪聲有幫助，歡迎在 App Store 為我們評分。"
          }
        }
      }
    },
