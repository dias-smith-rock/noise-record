    "settings.weighting.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الترجيح A يقارب السمع البشري؛ يُستخدمان C وZ للتحليل التقني وكامل النطاق."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A-weighting matches human hearing; C and Z are used for technical and full-band analysis."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ponderación A se aproxima a la audición humana; C y Z se usan para análisis técnico y de banda completa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pondération A suit l’audition humaine ; C et Z servent à l’analyse technique et pleine bande."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A-भारण मानव श्रवण के करीब है; C और Z तकनीकी/पूर्ण-बैंड विश्लेषण के लिए।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ponderação A aproxima a audição humana; C e Z são usadas para análise técnica e de banda completa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A-взвешивание близко к слуху человека; C и Z — для технического и полнополосного анализа."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A 计权贴近人耳听感；C 与 Z 用于技术与全频段分析。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A 計權貼近人耳聽感；C 與 Z 用於技術與全頻段分析。"
          }
        }
      }
    },
