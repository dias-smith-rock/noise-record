    "mode.standard.comparisonHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القراءات تطابق مدى علو الصوت لديك—مفيدة للمقارنة بالمعايير."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Readings match how loud it sounds to you—useful for comparing against noise standards."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las lecturas coinciden con lo fuerte que suena—útil para comparar con normas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mesures reflètent le volume ressenti—utile pour les normes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडिंग आपको जितना तेज़ लगता है उसके करीब—मानक से तुलना के लिए उपयोगी।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As leituras correspondem ao que você ouve—útil para comparar com normas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показания соответствуют субъективной громкости—удобно сравнивать с нормами."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读数贴近您感受到的响度，便于对照噪声标准。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀數貼近您感受到的響度，便於對照噪音標準。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Показанията съответстват на това колко силно ви звучи - полезно за сравнение със стандартите за шум."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Les lectures coincideixen amb el fort que et sona, útil per comparar-les amb els estàndards de soroll."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hodnoty odpovídají tomu, jak hlasitě vám to zní – užitečné pro srovnání s normami hluku."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Aflæsninger matcher, hvor højt det lyder for dig - nyttigt til sammenligning med støjstandarder."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Messwerte passen dazu, wie laut es für Sie klingt – nützlich für den Vergleich mit Lärmstandards."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι μετρήσεις ταιριάζουν με το πόσο δυνατό σας ακούγεται—χρήσιμο για σύγκριση με τα πρότυπα θορύβου."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lukemat vastaavat sitä, kuinka kovalta se sinusta kuulostaa – hyödyllinen vertailtaessa melustandardeihin."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קריאות תואמות את העוצמה שהיא נשמעת לך - שימושית להשוואה מול תקני רעש."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Očitanja odgovaraju tome koliko vam glasno zvuči—korisno za usporedbu sa standardima buke."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A leolvasott értékek megfelelnek annak, hogy milyen hangosan szól az Ön számára – ez hasznos a zajszabványokkal való összehasonlításhoz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembacaannya sesuai dengan seberapa keras suaranya bagi Anda—berguna untuk membandingkannya dengan standar kebisingan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le letture corrispondono a quanto forte ti suona: utile per il confronto con gli standard di rumore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "測定値は、その音がどのくらい大きく聞こえるかを表しており、騒音基準と比較するのに役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "판독값은 사용자에게 들리는 소리의 크기와 일치하므로 소음 표준과 비교하는 데 유용합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bacaan sepadan dengan bunyi yang kuat kepada anda—berguna untuk membandingkan dengan standard hingar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Målinger samsvarer med hvor høyt det høres ut for deg – nyttig for å sammenligne med støystandarder."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De metingen komen overeen met hoe luid het voor u klinkt, handig als u de geluidsnormen wilt vergelijken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczyty odpowiadają głośności dźwięku, co jest przydatne do porównania ze standardami hałasu."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Citirile se potrivesc cu cât de tare sună pentru dvs. — utile pentru compararea cu standardele de zgomot."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Hodnoty zodpovedajú tomu, ako nahlas to znie – užitočné na porovnanie so štandardmi hluku."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Avläsningar matchar hur högt det låter för dig – användbart för att jämföra med bullerstandarder."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การอ่านค่าจะจับคู่ความดังของเสียงกับคุณ ซึ่งมีประโยชน์ในการเปรียบเทียบกับมาตรฐานเสียงรบกวน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Okumalar size ne kadar yüksek ses çıkardığıyla eşleşir; gürültü standartlarıyla karşılaştırma yapmak için kullanışlıdır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Показання відповідають тому, наскільки голосно це звучить для вас — корисно для порівняння зі стандартами шуму."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các kết quả đo khớp với mức độ âm thanh mà bạn cảm thấy—hữu ích khi so sánh với các tiêu chuẩn về tiếng ồn."
          }
        }
      }
    },
    "mode.standard.coreDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحاكي إدراك الأذن البشرية للصوت، مع ترشيح الترددات الأقل حساسية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulates how the human ear perceives sound, filtering frequencies we are less sensitive to."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Simula cómo percibe el oído humano el sonido, filtrando frecuencias a las que somos menos sensibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Simule la perception sonore de l’oreille humaine en filtrant les fréquences moins sensibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मानव कान की ध्वनि अनुभूति की नकल करता है, कम संवेदनशील आवृत्तियाँ छानता है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Simula como o ouvido humano percebe o som, filtrando frequências às quais somos menos sensíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Имитирует восприятие звука ухом, отфильтровывая менее чувствительные частоты."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟人耳对声音的感知，滤除较不敏感的频率。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬人耳對聲音的感知，濾除較不敏感的頻率。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Симулира как човешкото ухо възприема звука, като филтрира честотите, към които сме по-малко чувствителни."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Simula com l'oïda humana percep el so, filtrant les freqüències a les quals som menys sensibles."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Simuluje, jak lidské ucho vnímá zvuk, filtruje frekvence, na které jsme méně citliví."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulerer, hvordan det menneskelige øre opfatter lyd, filtrerer frekvenser, vi er mindre følsomme over for."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Simuliert, wie das menschliche Ohr Geräusche wahrnimmt, und filtert Frequenzen, auf die wir weniger empfindlich reagieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσομοιώνει τον τρόπο με τον οποίο το ανθρώπινο αυτί αντιλαμβάνεται τον ήχο, φιλτράροντας τις συχνότητες στις οποίες είμαστε λιγότερο ευαίσθητοι."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Simuloi kuinka ihmiskorva havaitsee äänen, suodattaa taajuuksia, joille olemme vähemmän herkkiä."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מדמה איך האוזן האנושית תופסת קול, מסנן תדרים שאנו פחות רגישים אליהם."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulira kako ljudsko uho percipira zvuk, filtrirajući frekvencije na koje smo manje osjetljivi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Azt szimulálja, hogy az emberi fül hogyan érzékeli a hangot, szűri azokat a frekvenciákat, amelyekre kevésbé vagyunk érzékenyek."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mensimulasikan bagaimana telinga manusia merasakan suara, memfilter frekuensi yang kurang sensitif bagi kita."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Simula il modo in cui l'orecchio umano percepisce il suono, filtrando le frequenze a cui siamo meno sensibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "人間の耳が音を知覚する方法をシミュレートし、あまり敏感ではない周波数をフィルタリングします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인간의 귀가 소리를 인식하는 방식을 시뮬레이션하고 덜 민감한 주파수를 필터링합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mensimulasikan cara telinga manusia melihat bunyi, menapis frekuensi yang kita kurang sensitif."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulerer hvordan det menneskelige øret oppfatter lyd, filtrerer frekvenser vi er mindre følsomme for."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Simuleert hoe het menselijk oor geluid waarneemt en filtert frequenties waarvoor we minder gevoelig zijn."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Symuluje sposób, w jaki ludzkie ucho odbiera dźwięk, filtrując częstotliwości, na które jesteśmy mniej wrażliwi."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulează modul în care urechea umană percepe sunetul, filtrând frecvențele la care suntem mai puțin sensibili."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Simuluje, ako ľudské ucho vníma zvuk, pričom filtruje frekvencie, na ktoré sme menej citliví."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulerar hur det mänskliga örat uppfattar ljud, filtrerar frekvenser som vi är mindre känsliga för."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จำลองวิธีที่หูของมนุษย์รับรู้เสียง โดยกรองความถี่ที่เรามีความไวน้อยกว่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha az duyarlı olduğumuz frekansları filtreleyerek insan kulağının sesi nasıl algıladığını simüle eder."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Імітує те, як людське вухо сприймає звук, фільтруючи частоти, до яких ми менш чутливі."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mô phỏng cách tai con người cảm nhận âm thanh, lọc các tần số mà chúng ta ít nhạy cảm hơn."
          }
        }
      }
    },
