          "stringUnit": {
            "state": "translated",
            "value": "Ads have been permanently removed. Enjoy an uninterrupted experience."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "广告已永久移除，尽情享受无干扰的使用体验。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "廣告已永久移除，盡情享受無干擾的使用體驗。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Рекламите са премахнати за постоянно. Насладете се на изживяване без прекъсване."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els anuncis s'han eliminat permanentment. Gaudeix d'una experiència ininterrompuda."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Reklamy byly trvale odstraněny. Užijte si ničím nerušený zážitek."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Annoncer er blevet permanent fjernet. Nyd en uafbrudt oplevelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anzeigen wurden endgültig entfernt. Genießen Sie ein ungestörtes Erlebnis."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι διαφημίσεις έχουν αφαιρεθεί οριστικά. Απολαύστε μια αδιάκοπη εμπειρία."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mainokset on poistettu pysyvästi. Nauti keskeytymättömästä kokemuksesta."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המודעות הוסרו לצמיתות. תהנה מחוויה ללא הפרעה."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oglasi su trajno uklonjeni. Uživajte u neprekinutom iskustvu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hirdetéseket véglegesen eltávolítottuk. Élvezze a megszakítás nélküli élményt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Iklan telah dihapus secara permanen. Nikmati pengalaman tanpa gangguan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli annunci sono stati rimossi definitivamente. Goditi un'esperienza ininterrotta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "広告は完全に削除されました。途切れることのない体験をお楽しみください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "광고가 영구적으로 제거되었습니다. 중단 없는 경험을 즐겨보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Iklan telah dialih keluar secara kekal. Nikmati pengalaman tanpa gangguan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Annonsene er permanent fjernet. Nyt en uavbrutt opplevelse."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Advertenties zijn definitief verwijderd. Geniet van een ononderbroken ervaring."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Reklamy zostały trwale usunięte. Ciesz się nieprzerwanym doświadczeniem."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Anunțurile au fost eliminate definitiv. Bucurați-vă de o experiență neîntreruptă."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Reklamy boli natrvalo odstránené. Užite si ničím nerušený zážitok."
          }
        },
        "sv": {
