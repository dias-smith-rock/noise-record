    "settings.calibration.reset.alert.restored.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم مسح تعديلك اليدوي (%1$@).\n\nإجمالي الإزاحة: %2$@ → %3$@\nتعديل المستخدم: %4$@ → 0 dB\n\nتعود القراءات إلى الإعداد الافتراضي. أعد المعايرة بمقياس عند الحاجة."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Изчисти вашата ръчна корекция (%1$@).\n\nОбщо отместване: %2$@ → %3$@\nКорекция на потребителя: %4$@ → 0 dB\n\nПоказанията на монитора се връщат към фабричните настройки. Калибрирайте повторно с измервателен уред, ако е необходимо."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "S'ha esborrat l'ajust manual (%1$@).\n\nDesplaçament total: %2$@ → %3$@\nAjust d'usuari: %4$@ → 0 dB\n\nLes lectures del monitor tornen als valors predeterminats de fàbrica. Torneu a calibrar amb un mesurador si cal."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruční úprava byla vymazána (%1$@).\n\nCelkový posun: %2$@ → %3$@\nUživatelská úprava: %4$@ → 0 dB\n\nHodnoty monitoru se vrátí na výchozí tovární nastavení. V případě potřeby překalibrujte pomocí měřiče."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ryddede din manuelle justering (%1$@).\n\nSamlet offset: %2$@ → %3$@\nBrugerjustering: %4$@ → 0 dB\n\nSkærmaflæsninger vender tilbage til fabriksindstillingerne. Kalibrer om nødvendigt med en måler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre manuelle Anpassung wurde gelöscht (%1$@).\n\nGesamtoffset: %2$@ → %3$@\nBenutzeranpassung: %4$@ → 0 dB\n\nDie Monitorwerte werden auf die Werkseinstellungen zurückgesetzt. Bei Bedarf mit einem Messgerät neu kalibrieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαγράφηκε η μη αυτόματη προσαρμογή (%1$@).\n\nΣυνολική μετατόπιση: %2$@ → %3$@\nΠροσαρμογή χρήστη: %4$@ → 0 dB\n\nΟι ενδείξεις της οθόνης επιστρέφουν στις εργοστασιακές προεπιλογές. Βαθμονόμηση εκ νέου με μετρητή εάν χρειάζεται."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cleared your manual adjustment (%1$@).\n\nTotal offset: %2$@ → %3$@\nUser adjustment: %4$@ → 0 dB\n\nMonitor readings return to factory defaults. Recalibrate with a meter if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminó tu ajuste manual (%1$@).\n\nOffset total: %2$@ → %3$@\nAjuste del usuario: %4$@ → 0 dB\n\nLas lecturas vuelven a valores de fábrica. Recalibra con un medidor si hace falta."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tyhjennettiin manuaalinen säätö (%1$@).\n\nKokonaispoikkeama: %2$@ → %3$@\nKäyttäjän säätö: %4$@ → 0 dB\n\nNäytön lukemat palautuvat tehdasasetuksiin. Kalibroi tarvittaessa uudelleen mittarilla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre ajustement manuel (%1$@) a été effacé.\n\nOffset total : %2$@ → %3$@\nAjustement utilisateur : %4$@ → 0 dB\n\nLes mesures reviennent aux réglages d’usine. Réétalonnez si besoin."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ניקה את ההתאמה הידנית שלך (%1$@).\n\nסה\"כ היסט: %2$@ → %3$@\nהתאמת משתמש: %4$@ → 0 dB\n\nקריאות הצג חוזרות לברירות המחדל של היצרן. כיול מחדש עם מד במידת הצורך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका मैनुअल समायोजन (%1$@) हटाया गया।\n\nकुल ऑफ़सेट: %2$@ → %3$@\nउपयोगकर्ता समायोजन: %4$@ → 0 dB\n\nरीडिंग फ़ैक्टरी डिफ़ॉल्ट पर लौटती हैं। ज़रूरत हो तो मीटर से फिर कैलिब्रेट करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izbrisano je vaše ručno podešavanje (%1$@).\n\nUkupni pomak: %2$@ → %3$@\nKorisnička prilagodba: %4$@ → 0 dB\n\nOčitanja monitora vraćaju se na tvorničke postavke. Po potrebi ponovno kalibrirajte mjeračem."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Törölte a kézi beállítást (%1$@).\n\nTeljes eltolás: %2$@ → %3$@\nFelhasználói beállítás: %4$@ → 0 dB\n\nA monitor leolvasása visszaáll a gyári alapértékekre. Szükség esetén kalibrálja újra mérőműszerrel."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menghapus penyesuaian manual Anda (%1$@).\n\nTotal perpindahan: %2$@ → %3$@\nPenyesuaian pengguna: %4$@ → 0 dB\n\nPembacaan monitor kembali ke default pabrik. Kalibrasi ulang dengan meteran jika diperlukan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancellata la regolazione manuale (%1$@).\n\nOffset totale: %2$@ → %3$@\nRegolazione utente: %4$@ → 0 dB\n\nLe letture del monitor ritornano alle impostazioni di fabbrica. Se necessario, ricalibrare con un misuratore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動調整をクリアしました (%1$@)。\n\n合計オフセット: %2$@ → %3$@\nユーザー調整: %4$@ → 0 dB\n\nモニターの測定値が工場出荷時のデフォルトに戻ります。必要に応じてメーターを使用して再校正します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 조정(%1$@)을 삭제했습니다.\n\n총 오프셋: %2$@ → %3$@\n사용자 조정: %4$@ → 0 dB\n\n모니터 판독값이 공장 기본값으로 돌아갑니다. 필요한 경우 미터로 다시 교정하십시오."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengosongkan pelarasan manual anda (%1$@).\n\nJumlah offset: %2$@ → %3$@\nPelarasan pengguna: %4$@ → 0 dB\n\nPantau bacaan kembali kepada lalai kilang. Ukur semula dengan meter jika perlu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fjernet den manuelle justeringen (%1$@).\n\nTotal offset: %2$@ → %3$@\nBrukerjustering: %4$@ → 0 dB\n\nSkjermavlesninger går tilbake til fabrikkinnstillinger. Kalibrer på nytt med en måler om nødvendig."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw handmatige aanpassing gewist (%1$@).\n\nTotale verschuiving: %2$@ → %3$@\nGebruikersaanpassing: %4$@ → 0 dB\n\nDe monitorwaarden keren terug naar de fabrieksinstellingen. Kalibreer indien nodig opnieuw met een meter."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyczyszczono ręczną regulację (%1$@).\n\nCałkowite przesunięcie: %2$@ → %3$@\nRegulacja użytkownika: %4$@ → 0 dB\n\nOdczyty monitora powracają do ustawień fabrycznych. W razie potrzeby dokonaj ponownej kalibracji za pomocą miernika."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu ajuste manual (%1$@) foi removido.\n\nOffset total: %2$@ → %3$@\nAjuste do usuário: %4$@ → 0 dB\n\nAs leituras voltam ao padrão de fábrica. Recalibre com um medidor se necessário."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ați șters reglarea manuală (%1$@).\n\nCompensație totală: %2$@ → %3$@\nAjustare utilizator: %4$@ → 0 dB\n\nCitirile monitorului revin la valorile implicite din fabrică. Recalibrați cu un metru dacă este necesar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ручная поправка (%1$@) сброшена.\n\nСуммарное смещение: %2$@ → %3$@\nПользовательская поправка: %4$@ → 0 dB\n\nПоказания возвращаются к заводским. При необходимости откалибруйте снова."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vymazalo sa vaše manuálne nastavenie (%1$@).\n\nCelkový posun: %2$@ → %3$@\nÚprava používateľa: %4$@ → 0 dB\n\nHodnoty monitora sa vrátia na predvolené výrobné nastavenia. V prípade potreby prekalibrujte pomocou meracieho prístroja."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rensat din manuella justering (%1$@).\n\nTotal offset: %2$@ → %3$@\nAnvändarjustering: %4$@ → 0 dB\n\nMonitoravläsningarna återgår till fabriksinställningarna. Kalibrera om med en mätare om det behövs."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ล้างการปรับด้วยตนเองของคุณ (%1$@)\n\nออฟเซ็ตทั้งหมด: %2$@ → %3$@\nการปรับเปลี่ยนโดยผู้ใช้: %4$@ → 0 dB\n\nการอ่านค่าของจอภาพจะกลับไปสู่ค่าเริ่มต้นจากโรงงาน ปรับเทียบใหม่โดยใช้มิเตอร์หากจำเป็น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Manuel ayarınız silindi (%1$@).\n\nToplam ofset: %2$@ → %3$@\nKullanıcı ayarı: %4$@ → 0 dB\n\nMonitör okumaları fabrika varsayılanlarına döner. Gerekirse bir ölçüm cihazıyla yeniden kalibre edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистив ваше ручне коригування (%1$@).\n\nЗагальне зміщення: %2$@ → %3$@\nКоригування користувача: %4$@ → 0 dB\n\nПоказання монітора повертаються до заводських налаштувань. За потреби відкалібруйте за допомогою глюкометра."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã xóa điều chỉnh thủ công của bạn (%1$@).\n\nTổng giá trị bù đắp: %2$@ → %3$@\nNgười dùng điều chỉnh: %4$@ → 0 dB\n\nMàn hình đọc trở về mặc định của nhà máy. Hiệu chỉnh lại bằng máy đo nếu cần."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已清除手动调整（%1$@）。\n\n总偏移：%2$@ → %3$@\n用户调整：%4$@ → 0 dB\n\n监测读数恢复出厂默认。如有需要请重新校准。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已清除手動調整（%1$@）。\n\n總偏移：%2$@ → %3$@\n使用者調整：%4$@ → 0 dB\n\n監測讀數恢復出廠預設。如有需要請重新校準。"
          }
        }
      }
    },
