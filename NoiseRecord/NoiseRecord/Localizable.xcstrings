    "settings.accentColor.footer": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لكل من الوضعين القياسي والحساسية العالية استخدام لون مميز خاص بهما."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Режимите Standard и High Sensitivity могат да използват всеки свой собствен цвят на акцента."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els modes estàndard i d'alta sensibilitat poden utilitzar cadascun el seu propi color d'accent."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Režimy Standardní a Vysoká citlivost mohou každý používat svou vlastní barvu zvýraznění."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard- og High Sensitivity-tilstande kan hver bruge deres egen accentfarve."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Modi „Standard“ und „Hohe Empfindlichkeit“ können jeweils ihre eigene Akzentfarbe verwenden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι λειτουργίες Standard και High Sensitivity μπορούν να χρησιμοποιήσουν το δικό τους χρώμα έμφασης."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard and High Sensitivity modes can each use their own accent color."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los modos Estándar y Alta Sensibilidad pueden usar cada uno su propio color de acento."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakio- ja High Sensitivity -tilat voivat käyttää kukin omaa korostusväriään."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modes Standard et Haute sensibilité peuvent chacun utiliser leur propre couleur d'accentuation."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מצבים סטנדרטיים ורגישות גבוהה יכולים להשתמש בכל אחד בצבע המבטא שלו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मानक और उच्च संवेदनशीलता मोड प्रत्येक अपने स्वयं के उच्चारण रंग का उपयोग कर सकते हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Način rada Standard i High Sensitivity može koristiti svaki svoju boju naglaska."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A normál és a nagy érzékenységű módok mindegyike használhatja a saját kiemelő színét."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode Standar dan Sensitivitas Tinggi masing-masing dapat menggunakan warna aksennya sendiri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modalità Standard e Alta sensibilità possono utilizzare ciascuna il proprio colore principale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "標準モードと高感度モードでは、それぞれ独自のアクセントカラーを使用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "표준 및 고감도 모드는 각각 고유한 강조 색상을 사용할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mod Standard dan High Sensitiviti masing-masing boleh menggunakan warna aksen mereka sendiri."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard- og høyfølsomhetsmodus kan bruke hver sin aksentfarge."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De modi Standaard en Hoge gevoeligheid kunnen elk hun eigen accentkleur gebruiken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryby standardowa i wysoka czułość mogą używać własnego koloru akcentującego."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os modos Padrão e Alta Sensibilidade podem usar sua própria cor de destaque."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Modurile Standard și Sensibilitate ridicată pot folosi fiecare culoarea lor de accent."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждый из режимов «Стандартный» и «Высокая чувствительность» может использовать свой собственный цвет акцента."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Režimy Standard a High Sensitivity môžu používať svoju vlastnú zvýrazňujúcu farbu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard- och High Sensitivity-lägena kan var och en använda sin egen accentfärg."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โหมดมาตรฐานและโหมดความไวสูงแต่ละโหมดสามารถใช้สีเฉพาะจุดของตัวเองได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Standart ve Yüksek Hassasiyet modlarının her biri kendi vurgu rengini kullanabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кожен із режимів «Стандартний» і «Висока чутливість» може використовувати власний колір акценту."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mỗi chế độ Độ nhạy tiêu chuẩn và Độ nhạy cao có thể sử dụng màu nhấn riêng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准模式与高灵敏模式可分别设置主题色。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "標準模式與高靈敏模式可分別設定主題色。"
          }
        }
      }
    },
