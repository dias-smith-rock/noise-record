    "permission.microphone.denied.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter се нуждае от достъп до микрофона, за да измерва нивата на звука и да записва аудио. Активирайте го в Настройки."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter necessita accés al micròfon per mesurar els nivells de so i gravar àudio. Activeu-lo a Configuració."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter potřebuje přístup k mikrofonu, aby mohl měřit úrovně zvuku a nahrávat zvuk. Povolte jej v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter har brug for mikrofonadgang for at måle lydniveauer og optage lyd. Aktiver det i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter benötigt Zugriff auf das Mikrofon, um Schallpegel zu messen und Audio aufzunehmen. Aktivieren Sie es in den Einstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Decibel Meter χρειάζεται πρόσβαση στο μικρόφωνο για τη μέτρηση των επιπέδων ήχου και την εγγραφή ήχου. Ενεργοποιήστε το στις Ρυθμίσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter tarvitsee mikrofonin pääsyn äänitason mittaamiseen ja äänen tallentamiseen. Ota se käyttöön asetuksista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter זקוק לגישה למיקרופון כדי למדוד רמות קול ולהקליט אודיו. הפעל את זה בהגדרות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter treba pristup mikrofonu za mjerenje razine zvuka i snimanje zvuka. Omogućite ga u postavkama."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Decibel Meter mikrofon-hozzáférést igényel a hangszint méréséhez és a hang rögzítéséhez. Engedélyezze a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter memerlukan akses mikrofon untuk mengukur level suara dan merekam audio. Aktifkan di Pengaturan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter necessita dell'accesso al microfono per misurare i livelli sonori e registrare l'audio. Abilitalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter では、騒音レベルの測定と音声の録音のためにマイクへのアクセスが必要です。設定で有効にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter은 소음 수준을 측정하고 오디오를 녹음하려면 마이크 액세스 권한이 필요합니다. 설정에서 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter memerlukan akses mikrofon untuk mengukur tahap bunyi dan merakam audio. Dayakannya dalam Tetapan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter trenger mikrofontilgang for å måle lydnivåer og ta opp lyd. Aktiver det i Innstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter heeft microfoontoegang nodig om het geluidsniveau te meten en audio op te nemen. Schakel het in Instellingen in."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter potrzebuje dostępu do mikrofonu, aby mierzyć poziom dźwięku i nagrywać dźwięk. Włącz to w Ustawieniach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter are nevoie de acces la microfon pentru a măsura nivelurile de sunet și pentru a înregistra sunet. Activați-l în Setări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter needs microphone access to measure sound levels and record audio. Enable it in Settings."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter potrebuje prístup k mikrofónu na meranie úrovní zvuku a nahrávanie zvuku. Povoľte ho v Nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter behöver mikrofonåtkomst för att mäta ljudnivåer och spela in ljud. Aktivera det i Inställningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter ต้องการเข้าถึงไมโครโฟนเพื่อวัดระดับเสียงและบันทึกเสียง เปิดใช้งานได้ในการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter'nin ses seviyelerini ölçmek ve ses kaydetmek için mikrofon erişimine ihtiyacı var. Ayarlar'da etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter потребує доступу до мікрофона, щоб вимірювати рівні звуку та записувати звук. Увімкніть це в налаштуваннях."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter cần quyền truy cập vào micrô để đo mức âm thanh và ghi lại âm thanh. Kích hoạt nó trong Cài đặt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter 需要麦克风权限以测量噪声并录音。请在设置中开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Decibel Meter 需要麥克風權限以測量噪聲並錄音。請在設定中開啟。"
          }
        }
      }
    },
