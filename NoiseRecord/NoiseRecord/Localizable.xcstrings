    "settings.calibration.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خط الأساس لإزاحة الوضع 115–118 dB؛ يجب أن تقرأ غرفة هادئة نحو 30–40 dB. اضبط بمقياس احترافي عند الحاجة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mode offset baseline is 115–118 dB; a quiet room should read about 30–40 dB. Fine-tune with a professional meter if needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La línea base de offset del modo es 115–118 dB; una habitación tranquila debería marcar unos 30–40 dB. Ajusta con un sonómetro profesional si hace falta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La base d’offset du mode est de 115–118 dB ; une pièce calme devrait afficher environ 30–40 dB. Ajustez avec un sonomètre pro si besoin."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मोड ऑफ़सेट बेसलाइन 115–118 dB है; शांत कमरे में लगभग 30–40 dB दिखना चाहिए। ज़रूरत हो तो प्रो मीटर से फाइन-ट्यून करें।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A linha de base de offset do modo é 115–118 dB; um ambiente silencioso deve marcar cerca de 30–40 dB. Ajuste com um medidor profissional se necessário."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Базовое смещение режима 115–118 dB; в тихой комнате должно быть около 30–40 dB. При необходимости подстройте профессиональным шумомером."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "模式偏移基线约为 115–118 dB；安静房间读数约 30–40 dB。如有需要请用专业声级计微调。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "模式偏移基線約為 115–118 dB；安靜房間讀數約 30–40 dB。如有需要請用專業聲級計微調。"
          }
        }
      }
    },
