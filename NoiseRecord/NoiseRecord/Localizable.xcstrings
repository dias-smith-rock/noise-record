    "permission.photos.denied.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم الوصول إلى مكتبة الصور لحفظ مقاطع الفيديو في ألبومك. تمكينه في الإعدادات."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Необходим е достъп до библиотека със снимки, за да запазите видеоклипове във вашия албум. Активирайте го в Настройки."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Cal accedir a la biblioteca de fotos per desar vídeos al vostre àlbum. Activeu-lo a Configuració."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "K ukládání videí do alba je vyžadován přístup do knihovny fotografií. Povolte jej v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der kræves adgang til fotobiblioteket for at gemme videoer i dit album. Aktiver det i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Speichern von Videos in Ihrem Album ist Zugriff auf die Fotobibliothek erforderlich. Aktivieren Sie es in den Einstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απαιτείται πρόσβαση στη βιβλιοθήκη φωτογραφιών για την αποθήκευση βίντεο στο άλμπουμ σας. Ενεργοποιήστε το στις Ρυθμίσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Photo library access is required to save videos to your album. Enable it in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere acceso a la biblioteca de fotos para guardar videos en su álbum. Habilítelo en Configuración."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valokuvakirjaston käyttöoikeus vaaditaan videoiden tallentamiseen albumiisi. Ota se käyttöön asetuksista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès à la photothèque est requis pour enregistrer des vidéos dans votre album. Activez-le dans Paramètres."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נדרשת גישה לספריית תמונות כדי לשמור סרטונים באלבום שלך. הפעל את זה בהגדרות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके एल्बम में वीडियो सहेजने के लिए फोटो लाइब्रेरी का उपयोग आवश्यक है। इसे सेटिंग्स में सक्षम करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Za spremanje videozapisa u album potreban je pristup biblioteci fotografija. Omogućite ga u postavkama."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A videók albumba mentéséhez hozzáférésre van szükség a fotókönyvtárban. Engedélyezze a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses perpustakaan foto diperlukan untuk menyimpan video ke album Anda. Aktifkan di Pengaturan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per salvare i video nel tuo album è necessario l'accesso alla libreria fotografica. Abilitalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビデオをアルバムに保存するには、フォト ライブラリへのアクセスが必要です。設定で有効にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앨범에 동영상을 저장하려면 사진 라이브러리 접근 권한이 필요합니다. 설정에서 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses pustaka foto diperlukan untuk menyimpan video ke album anda. Dayakannya dalam Tetapan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgang til bildebibliotek er nødvendig for å lagre videoer i albumet ditt. Aktiver det i Innstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om video's in uw album op te slaan, is toegang tot de fotobibliotheek vereist. Schakel het in Instellingen in."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Do zapisywania filmów w albumie wymagany jest dostęp do biblioteki zdjęć. Włącz to w Ustawieniach."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à biblioteca de fotos é necessário para salvar vídeos em seu álbum. Habilite-o em Configurações."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesul la biblioteca foto este necesar pentru a salva videoclipurile în albumul dvs. Activați-l în Setări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для сохранения видео в альбом необходим доступ к библиотеке фотографий. Включите его в настройках."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Na ukladanie videí do albumu je potrebný prístup do knižnice fotografií. Povoľte ho v Nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillgång till fotobibliotek krävs för att spara videor i ditt album. Aktivera det i Inställningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จำเป็นต้องเข้าถึงไลบรารีรูปภาพเพื่อบันทึกวิดีโอลงในอัลบั้มของคุณ เปิดใช้งานได้ในการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Videoları albümünüze kaydetmek için fotoğraf kütüphanesine erişim gereklidir. Ayarlar'da etkinleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб зберігати відео в альбомі, потрібен доступ до бібліотеки фотографій. Увімкніть це в налаштуваннях."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần có quyền truy cập thư viện ảnh để lưu video vào album của bạn. Kích hoạt nó trong Cài đặt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要相册权限才能将视频保存到相册，请在设置中开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要相簿權限才能將影片儲存到相簿，請在設定中開啟。"
          }
        }
      }
    },
