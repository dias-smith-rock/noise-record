    "settings.removeAds.sheet.subheadline": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Платете веднъж. Поддържайте достъп без реклами на всяко устройство, в което сте влезли във вашия Apple ID."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Paga una vegada. Mantingueu l'accés sense anuncis a tots els dispositius connectats al vostre ID d'Apple."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaplať jednou. Udržujte přístup bez reklam na každém zařízení přihlášeném ke svému Apple ID."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Betal én gang. Hold reklamefri adgang på alle enheder, der er logget ind på dit Apple ID."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zahlen Sie einmal. Behalten Sie den werbefreien Zugriff auf jedem Gerät, das mit Ihrer Apple-ID angemeldet ist."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πληρώστε μια φορά. Διατηρήστε πρόσβαση χωρίς διαφημίσεις σε κάθε συσκευή που είναι συνδεδεμένη στο Apple ID σας."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Maksa kerran. Säilytä mainoksiton käyttö kaikilla Apple ID:lläsi kirjautuneilla laitteilla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שלם פעם אחת. שמור על גישה ללא פרסומות בכל מכשיר המחובר ל-Apple ID שלך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Platite jednom. Zadržite pristup bez oglasa na svakom uređaju na kojem ste prijavljeni na svoj Apple ID."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Fizessen egyszer. Tartsa meg a hirdetések nélküli hozzáférést minden olyan eszközön, amelyen az Apple ID-jával van bejelentkezve."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bayar sekali. Pertahankan akses bebas iklan di setiap perangkat yang masuk ke ID Apple Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Paga una volta. Mantieni l'accesso senza pubblicità su tutti i dispositivi su cui hai effettuato l'accesso al tuo ID Apple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一度お支払いください。 Apple ID にサインインしているすべてのデバイスで広告なしでアクセスできるようにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 번만 지불하세요. Apple ID로 로그인한 모든 기기에서 광고 없이 액세스할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bayar sekali. Kekalkan akses tanpa iklan pada setiap peranti yang dilog masuk ke Apple ID anda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Betal én gang. Hold annonsefri tilgang på alle enheter som er logget på Apple-ID-en din."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Betaal een keer. Houd advertentievrije toegang op elk apparaat waarop u bent ingelogd met uw Apple ID."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapłać raz. Zachowaj dostęp bez reklam na każdym urządzeniu zalogowanym na swoim Apple ID."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Plătește o dată. Păstrați accesul fără reclame pe fiecare dispozitiv conectat la ID-ul dvs. Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Pay once. Keep ad-free access on every device signed into your Apple ID."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaplaťte raz. Zachovajte si prístup bez reklám na každom zariadení prihlásenom do svojho Apple ID."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Betala en gång. Behåll annonsfri åtkomst på alla enheter som är inloggade på ditt Apple-ID."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จ่ายครั้งเดียว ให้การเข้าถึงแบบไม่มีโฆษณาบนอุปกรณ์ทุกเครื่องที่ลงชื่อเข้าใช้ Apple ID ของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir kez öde. Apple Kimliğinizle oturum açtığınız her cihazda reklamsız erişim sağlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Платіть один раз. Зберігайте доступ без реклами на кожному пристрої, де ви ввійшли у свій Apple ID."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trả tiền một lần. Giữ quyền truy cập không có quảng cáo trên mọi thiết bị đã đăng nhập vào ID Apple của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次付费，登录同一 Apple ID 的设备均可免广告。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一次付費，登入同一 Apple ID 的裝置均可免廣告。"
          }
        }
      }
    },
