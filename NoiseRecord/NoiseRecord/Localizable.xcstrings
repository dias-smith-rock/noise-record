        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הגדר מתי ההקלטה מתחילה ומפסיקה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्डिंग शुरू/रुकने की सीमा सेट करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Postavite kada snimanje počinje i kada se zaustavlja."
