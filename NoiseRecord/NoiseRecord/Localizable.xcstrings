    "watch.monitoring.batteryNotice": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مراقبة الساعة تستهلك المزيد من البطارية. توقف عند الانتهاء."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Наблюдението на часовника изразходва повече батерия. Спрете, когато приключите."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La supervisió del rellotge utilitza més bateria. Atureu-vos quan acabeu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorování hodinek spotřebovává více baterie. Po dokončení zastavte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Urovervågning bruger mere batteri. Stop når du er færdig."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Überwachung der Uhr verbraucht mehr Batterie. Hören Sie auf, wenn Sie fertig sind."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η παρακολούθηση ρολογιών χρησιμοποιεί περισσότερη μπαταρία. Σταματήστε όταν τελειώσετε."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Watch monitoring uses more battery. Stop when finished."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La monitorización del reloj consume más batería. Deténgase cuando haya terminado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kellon valvonta kuluttaa enemmän akkua. Pysäytä, kun olet valmis."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La surveillance de la montre utilise plus de batterie. Arrêtez-vous lorsque vous avez terminé."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ניטור השעון משתמש יותר בסוללה. עצור כשתסיים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "घड़ी की निगरानी में अधिक बैटरी का उपयोग होता है। समाप्त होने पर रुकें."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Praćenje sata troši više baterije. Zaustavite se kada završite."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az órafigyelés több akkumulátort használ. Ha végzett, hagyja abba."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemantauan jam tangan menggunakan lebih banyak baterai. Berhenti setelah selesai."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il monitoraggio dell'orologio utilizza più batteria. Fermati quando hai finito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "時計の監視ではより多くのバッテリーが消費されます。終わったら停止します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시계 모니터링은 배터리를 더 많이 사용합니다. 완료되면 중지하십시오."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemantauan jam tangan menggunakan lebih banyak bateri. Berhenti apabila selesai."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Klokkeovervåking bruker mer batteri. Stopp når du er ferdig."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kijkmonitoring verbruikt meer batterij. Stop als je klaar bent."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorowanie zegarka zużywa więcej baterii. Zatrzymaj się, gdy skończysz."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O monitoramento do relógio consome mais bateria. Pare quando terminar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorizarea ceasului folosește mai multă baterie. Oprește-te când ai terminat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мониторинг часов расходует больше заряда батареи. Остановитесь, когда закончите."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorovanie hodiniek spotrebuje viac batérie. Po dokončení zastavte."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klockövervakning använder mer batteri. Stoppa när du är klar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การตรวจสอบนาฬิกาใช้แบตเตอรี่มากขึ้น หยุดเมื่อเสร็จแล้ว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat izleme daha fazla pil kullanır. Bitirdiğinizde durun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Моніторинг годинника споживає більше заряду батареї. Зупиніть, коли закінчите."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giám sát đồng hồ sử dụng nhiều pin hơn. Dừng lại khi hoàn thành."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手表监测会更快耗电，用完后请停止。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "手錶監測會更快耗電，用完後請停止。"
          }
        }
      }
    },
