          "stringUnit": {
            "state": "translated",
            "value": "録音の開始時と停止時に設定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹화가 시작되고 중지되는 시점을 설정합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
