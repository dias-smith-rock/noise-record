    "settings.removeAds.alert.pending.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase is waiting for approval. Ads will be removed automatically once it completes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买正在等待批准，完成后将自动移除广告。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "購買正在等待批准，完成後將自動移除廣告。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Вашата покупка чака одобрение. Рекламите ще бъдат премахнати автоматично, след като приключи."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva compra està pendent d'aprovació. Els anuncis s'eliminaran automàticament un cop hagi finalitzat."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš nákup čeká na schválení. Po dokončení budou reklamy automaticky odstraněny."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit køb venter på godkendelse. Annoncer fjernes automatisk, når de er færdige."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Kauf wartet auf die Genehmigung. Anzeigen werden automatisch entfernt, sobald der Vorgang abgeschlossen ist."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αγορά σας περιμένει έγκριση. Οι διαφημίσεις θα αφαιρεθούν αυτόματα μόλις ολοκληρωθεί."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ostoksesi odottaa hyväksyntää. Mainokset poistetaan automaattisesti, kun se on valmis."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הרכישה שלך ממתינה לאישור. מודעות יוסרו אוטומטית לאחר השלמתה."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša kupnja čeka odobrenje. Oglasi će se automatski ukloniti kada završi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A vásárlás jóváhagyásra vár. A hirdetéseket a rendszer automatikusan eltávolítja, amint befejeződik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembelian Anda sedang menunggu persetujuan. Iklan akan dihapus secara otomatis setelah selesai."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo acquisto è in attesa di approvazione. Gli annunci verranno rimossi automaticamente una volta completato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入は承認を待っています。広告は完了すると自動的に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구매가 승인 대기 중입니다. 광고는 완료되면 자동으로 제거됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembelian anda sedang menunggu kelulusan. Iklan akan dialih keluar secara automatik sebaik sahaja ia selesai."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kjøpet ditt venter på godkjenning. Annonsene fjernes automatisk når de er fullført."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw aankoop wacht op goedkeuring. Advertenties worden automatisch verwijderd zodra deze is voltooid."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój zakup oczekuje na zatwierdzenie. Reklamy zostaną automatycznie usunięte po zakończeniu."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Achiziția dvs. așteaptă aprobarea. Anunțurile vor fi eliminate automat odată ce se finalizează."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš nákup čaká na schválenie. Po dokončení budú reklamy automaticky odstránené."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ditt köp väntar på godkännande. Annonserna tas bort automatiskt när de är klara."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การซื้อของคุณกำลังรอการอนุมัติ โฆษณาจะถูกลบโดยอัตโนมัติเมื่อเสร็จสิ้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Satın alma işleminiz onay bekliyor. Reklamlar tamamlandığında otomatik olarak kaldırılacaktır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша покупка очікує на підтвердження. Оголошення буде видалено автоматично після його завершення."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giao dịch mua hàng của bạn đang chờ phê duyệt. Quảng cáo sẽ tự động bị xóa sau khi hoàn tất."
          }
        }
      }
    },
