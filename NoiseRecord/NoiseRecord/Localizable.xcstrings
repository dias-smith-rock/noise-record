    "recorderSettings.voiceActivated.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبدأ ويوقف المقاطع عند تجاوز الصوت للحدود."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Стартирайте и спирайте клипове, когато звукът премине вашите прагове."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia i atura els clips quan el so traspassa els teus llindars."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Spusťte a zastavte klipy, když zvuk překročí vaše prahové hodnoty."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Start og stop klip, når lyden krydser dine tærskler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starten und stoppen Sie Clips, wenn der Ton Ihre Schwellenwerte überschreitet."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ξεκινήστε και σταματήστε τα κλιπ όταν ο ήχος ξεπεράσει τα κατώφλια σας."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start and stop clips when sound crosses your thresholds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia y detiene clips cuando el sonido supera tus umbrales."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aloita ja lopeta leikkeet, kun ääni ylittää kynnyksesi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarre et arrête les clips lorsque le son dépasse vos seuils."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התחל והפסק קליפים כאשר הקול חוצה את הספים שלך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ध्वनि सीमा पार करने पर क्लिप शुरू/रोकें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokrenite i zaustavite isječke kada zvuk prijeđe vaše pragove."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Indítsa el és állítsa le a klipeket, amikor a hang átlépi a küszöböt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulai dan hentikan klip saat suara melewati ambang batas Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Avvia e interrompi le clip quando il suono supera le tue soglie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音が閾値を超えたときにクリップを開始および停止します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사운드가 임계값을 초과하면 클립을 시작하고 중지합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulakan dan hentikan klip apabila bunyi melepasi ambang anda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Start og stopp klipp når lyden krysser terskelverdiene dine."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Start en stop clips wanneer geluid uw drempels overschrijdt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uruchamiaj i zatrzymuj klipy, gdy dźwięk przekroczy Twoje progi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia e para clipes quando o som ultrapassa seus limites."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Porniți și opriți clipurile atunci când sunetul vă depășește pragurile."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запускает и останавливает клипы при пересечении порогов."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Spustite a zastavte klipy, keď zvuk prekročí vaše prahové hodnoty."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Starta och stoppa klipp när ljudet passerar dina trösklar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เริ่มและหยุดคลิปเมื่อเสียงเกินขีดจำกัดของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ses eşiklerinizi aştığında klipleri başlatın ve durdurun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запускайте та зупиняйте кліпи, коли звук переступає ваші пороги."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bắt đầu và dừng clip khi âm thanh vượt quá ngưỡng của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "声音超过阈值时自动开始和停止录音。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "聲音超過閾值時自動開始和停止錄音。"
          }
        }
      }
    },
