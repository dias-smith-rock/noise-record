    "settings.calibration.alert.saved.changed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت المعايرة إلى مستوى المرجع %1$d dB.\n\nتعديل المستخدم: %2$@ → %3$@\nإجمالي الإزاحة: %4$@\n\nستستخدم القراءات خط الأساس الجديد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrated to reference level %1$d dB.\n\nUser adjustment: %2$@ → %3$@\nTotal offset: %4$@\n\nMonitor readings will use the new baseline."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrado al nivel de referencia %1$d dB.\n\nAjuste del usuario: %2$@ → %3$@\nOffset total: %4$@\n\nLas lecturas usarán la nueva línea base."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étalonné au niveau de référence %1$d dB.\n\nAjustement utilisateur : %2$@ → %3$@\nOffset total : %4$@\n\nLes mesures utiliseront la nouvelle base."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$d dB संदर्भ स्तर पर कैलिब्रेट किया गया।\n\nउपयोगकर्ता समायोजन: %2$@ → %3$@\nकुल ऑफ़सेट: %4$@\n\nरीडिंग नई बेसलाइन का उपयोग करेंगी।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrado para o nível de referência %1$d dB.\n\nAjuste do usuário: %2$@ → %3$@\nOffset total: %4$@\n\nAs leituras usarão a nova linha de base."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Калибровка по опорному уровню %1$d dB.\n\nПользовательская поправка: %2$@ → %3$@\nСуммарное смещение: %4$@\n\nПоказания будут использовать новую базу."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已校准至参考声级 %1$d dB。\n\n用户调整：%2$@ → %3$@\n总偏移：%4$@\n\n监测读数将使用新基线。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已校準至參考聲級 %1$d dB。\n\n使用者調整：%2$@ → %3$@\n總偏移：%4$@\n\n監測讀數將使用新基線。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Калибриран до референтно ниво %1$d dB.\n\nКорекция на потребителя: %2$@ → %3$@\nОбщо отместване: %4$@\n\nПоказанията на монитора ще използват новата базова линия."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrat al nivell de referència %1$d dB.\n\nAjust d'usuari: %2$@ → %3$@\nDesplaçament total: %4$@\n\nLes lectures del monitor utilitzaran la nova línia de base."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrováno na referenční úroveň %1$d dB.\n\nUživatelská úprava: %2$@ → %3$@\nCelkový posun: %4$@\n\nMonitorované hodnoty budou používat novou základní linii."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibreret til referenceniveau %1$d dB.\n\nBrugerjustering: %2$@ → %3$@\nSamlet offset: %4$@\n\nMonitoraflæsninger vil bruge den nye baseline."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibriert auf Referenzniveau %1$d dB.\n\nBenutzeranpassung: %2$@ → %3$@\nGesamtversatz: %4$@\n\nMonitormesswerte verwenden die neue Basislinie."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Βαθμονομήθηκε στο επίπεδο αναφοράς %1$d dB.\n\nΠροσαρμογή χρήστη: %2$@ → %3$@\nΣυνολική μετατόπιση: %4$@\n\nΟι μετρήσεις της οθόνης θα χρησιμοποιούν τη νέα γραμμή βάσης."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibroitu viitetasolle %1$d dB.\n\nKäyttäjän säätö: %2$@ → %3$@\nKokonaispoikkeama: %4$@\n\nMonitorilukemat käyttävät uutta perusviivaa."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מכויל לרמת הייחוס %1$d dB.\n\nהתאמת משתמש: %2$@ → %3$@\nסה\"כ היסט: %4$@\n\nקריאות הצג ישתמשו בקו הבסיס החדש."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrirano na referentnu razinu %1$d dB.\n\nKorisnička prilagodba: %2$@ → %3$@\nUkupni pomak: %4$@\n\nOčitavanja monitora koristit će novu osnovnu liniju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A %1$d dB referenciaszintre kalibrálva.\n\nFelhasználói beállítás: %2$@ → %3$@\nTeljes eltolás: %4$@\n\nA monitor leolvasása az új alapvonalat fogja használni."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikalibrasi ke tingkat referensi %1$d dB.\n\nPenyesuaian pengguna: %2$@ → %3$@\nTotal offset: %4$@\n\nPembacaan monitor akan menggunakan baseline baru."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrato al livello di riferimento %1$d dB.\n\nRegolazione utente: %2$@ → %3$@\nScostamento totale: %4$@\n\nLe letture del monitor utilizzeranno la nuova linea di base."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "基準レベル %1$d dB に校正済み。\n\nユーザー調整: %2$@ → %3$@\n合計オフセット: %4$@\n\nモニターの測定値には新しいベースラインが使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기준 레벨 %1$d dB로 교정되었습니다.\n\n사용자 조정: %2$@ → %3$@\n총 오프셋: %4$@\n\n모니터 판독값은 새로운 기준을 사용합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ditentukur kepada tahap rujukan %1$d dB.\n\nPelarasan pengguna: %2$@ → %3$@\nJumlah offset: %4$@\n\nBacaan pantau akan menggunakan garis dasar baharu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrert til referansenivå %1$d dB.\n\nBrukerjustering: %2$@ → %3$@\nTotal offset: %4$@\n\nMonitoravlesninger vil bruke den nye grunnlinjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gekalibreerd op referentieniveau %1$d dB.\n\nGebruikersaanpassing: %2$@ → %3$@\nTotale compensatie: %4$@\n\nMonitormetingen zullen de nieuwe basislijn gebruiken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrowany do poziomu odniesienia %1$d dB.\n\nRegulacja użytkownika: %2$@ → %3$@\nCałkowite przesunięcie: %4$@\n\nOdczyty monitora będą korzystać z nowej linii bazowej."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrat la nivelul de referință %1$d dB.\n\nAjustare utilizator: %2$@ → %3$@\nCompensație totală: %4$@\n\nCitirile monitorului vor folosi noua linie de bază."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrované na referenčnú úroveň %1$d dB.\n\nÚprava používateľa: %2$@ → %3$@\nCelkový posun: %4$@\n\nMonitorované hodnoty budú používať novú základnú líniu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrerad till referensnivå %1$d dB.\n\nAnvändarjustering: %2$@ → %3$@\nTotal offset: %4$@\n\nMonitoravläsningar kommer att använda den nya baslinjen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปรับเทียบเป็นระดับอ้างอิง %1$d dB\n\nการปรับเปลี่ยนโดยผู้ใช้: %2$@ → %3$@\nออฟเซ็ตทั้งหมด: %4$@\n\nการอ่านค่าจากจอภาพจะใช้พื้นฐานใหม่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$d dB referans düzeyine kalibre edildi.\n\nKullanıcı ayarı: %2$@ → %3$@\nToplam sapma: %4$@\n\nMonitör okumaları yeni temel çizgiyi kullanacaktır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відкалібровано до еталонного рівня %1$d dB.\n\nКоригування користувача: %2$@ → %3$@\nЗагальне зміщення: %4$@\n\nПоказання монітора використовуватимуть нову базову лінію."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã hiệu chỉnh theo mức tham chiếu %1$d dB.\n\nNgười dùng điều chỉnh: %2$@ → %3$@\nTổng số tiền bù đắp: %4$@\n\nCác bài đọc trên màn hình sẽ sử dụng đường cơ sở mới."
          }
        }
      }
    },
    "settings.calibration.alert.saved.small": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم حفظ المعايرة. كان التعديل صغيرًا جدًا.\n\nتعديل المستخدم: %1$@\nإجمالي الإزاحة: %2$@\n\nتابع المراقبة وقارن بمقياس الصوت."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibration saved. The adjustment was very small.\n\nUser adjustment: %1$@\nTotal offset: %2$@\n\nKeep monitoring and compare against your sound level meter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibración guardada. El ajuste fue muy pequeño.\n\nAjuste del usuario: %1$@\nOffset total: %2$@\n\nSigue monitorizando y compáralo con tu sonómetro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étalonnage enregistré. L’ajustement était très faible.\n\nAjustement utilisateur : %1$@\nOffset total : %2$@\n\nContinuez la surveillance et comparez avec votre sonomètre."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैलिब्रेशन सहेजा गया। समायोजन बहुत छोटा था।\n\nउपयोगकर्ता समायोजन: %1$@\nकुल ऑफ़सेट: %2$@\n\nमॉनिटरिंग जारी रखें और साउंड लेवल मीटर से तुलना करें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibração salva. O ajuste foi muito pequeno.\n\nAjuste do usuário: %1$@\nOffset total: %2$@\n\nContinue monitorando e compare com seu decibelímetro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Калибровка сохранена. Поправка была очень небольшой.\n\nПользовательская поправка: %1$@\nСуммарное смещение: %2$@\n\nПродолжайте мониторинг и сравнивайте с шумомером."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "校准已保存。调整幅度很小。\n\n用户调整：%1$@\n总偏移：%2$@\n\n请继续监测并与声级计对比。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "校準已儲存。調整幅度很小。\n\n使用者調整：%1$@\n總偏移：%2$@\n\n請繼續監測並與聲級計比對。"
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Калибрирането е запазено. Корекцията беше много малка.\n\nПотребителска корекция: %1$@\nОбщо отместване: %2$@\n\nПродължавайте да наблюдавате и сравнявайте с вашия шумомер."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "S'ha guardat la calibració. L'ajust va ser molt petit.\n\nAjust d'usuari: %1$@\nDesplaçament total: %2$@\n\nSeguiu supervisant i compareu amb el vostre sonòmetre."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrace uložena. Úprava byla velmi malá.\n\nUživatelská úprava: %1$@\nCelkový posun: %2$@\n\nPokračujte ve sledování a porovnávejte se svým zvukoměrem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrering gemt. Justeringen var meget lille.\n\nBrugerjustering: %1$@\nSamlet offset: %2$@\n\nBliv ved med at overvåge og sammenlign med din lydniveaumåler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrierung gespeichert. Die Anpassung war sehr gering.\n\nBenutzeranpassung: %1$@\nGesamtoffset: %2$@\n\nBehalten Sie die Überwachung im Auge und vergleichen Sie sie mit Ihrem Schallpegelmesser."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η βαθμονόμηση αποθηκεύτηκε. Η προσαρμογή ήταν πολύ μικρή.\n\nΠροσαρμογή χρήστη: %1$@\nΣυνολική μετατόπιση: %2$@\n\nΣυνεχίστε να παρακολουθείτε και να συγκρίνετε με τον ηχομετρητή σας."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrointi tallennettu. Säätö oli hyvin pieni.\n\nKäyttäjän säätö: %1$@\nKokonaispoikkeama: %2$@\n\nJatka seurantaa ja vertaa äänitasomittariisi."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הכיול נשמר. ההתאמה הייתה קטנה מאוד.\n\nהתאמת משתמש: %1$@\nסה\"כ היסט: %2$@\n\nהמשיכו לעקוב ולהשוות מול מד רמת הקול שלכם."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibracija je spremljena. Prilagodba je bila vrlo mala.\n\nKorisnička prilagodba: %1$@\nUkupni pomak: %2$@\n\nNastavite pratiti i uspoređivati sa svojim mjeračem razine zvuka."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kalibrálás mentve. A kiigazítás nagyon kicsi volt.\n\nFelhasználói korrekció: %1$@\nTeljes eltolás: %2$@\n\nFolytassa a monitorozást és hasonlítsa össze a hangszintmérővel."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrasi disimpan. Penyesuaiannya sangat kecil.\n\nPenyesuaian pengguna: %1$@\nTotal offset: %2$@\n\nTerus pantau dan bandingkan dengan pengukur tingkat suara Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrazione salvata. L'aggiustamento è stato molto piccolo.\n\nRegolazione utente: %1$@\nScostamento totale: %2$@\n\nContinua a monitorare e confronta con il tuo fonometro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャリブレーションが保存されました。調整は非常に小さかったです。\n\nユーザー調整: %1$@\n合計オフセット: %2$@\n\nモニタリングを続けて、騒音計と比較してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보정이 저장되었습니다. 조정은 매우 작았습니다.\n\n사용자 조정: %1$@\n총 오프셋: %2$@\n\n계속 모니터링하고 소음 측정기와 비교해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penentukuran disimpan. Pelarasan itu sangat kecil.\n\nPelarasan pengguna: %1$@\nJumlah offset: %2$@\n\nTeruskan memantau dan membandingkan dengan meter paras bunyi anda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrering lagret. Justeringen var veldig liten.\n\nBrukerjustering: %1$@\nTotal offset: %2$@\n\nFortsett å overvåke og sammenlign med lydnivåmåleren."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibratie opgeslagen. De aanpassing was heel klein.\n\nGebruikersaanpassing: %1$@\nTotale compensatie: %2$@\n\nBlijf monitoren en vergelijk met uw geluidsniveaumeter."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibracja zapisana. Korekta była bardzo mała.\n\nRegulacja użytkownika: %1$@\nCałkowite przesunięcie: %2$@\n\nMonitoruj i porównuj z miernikiem poziomu dźwięku."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Calibrarea a fost salvată. Ajustarea a fost foarte mică.\n\nAjustare utilizator: %1$@\nCompensație totală: %2$@\n\nMonitorizați în continuare și comparați cu sonometrul dvs."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrácia bola uložená. Úprava bola veľmi malá.\n\nÚprava používateľa: %1$@\nCelkový posun: %2$@\n\nPokračujte v monitorovaní a porovnávaní so svojím zvukomerom."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrering sparad. Justeringen var mycket liten.\n\nAnvändarjustering: %1$@\nTotal offset: %2$@\n\nFortsätt övervaka och jämför med din ljudnivåmätare."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกการปรับเทียบแล้ว การปรับมีขนาดเล็กมาก\n\nการปรับเปลี่ยนโดยผู้ใช้: %1$@\nออฟเซ็ตทั้งหมด: %2$@\n\nติดตามและเปรียบเทียบกับเครื่องวัดระดับเสียงของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalibrasyon kaydedildi. Ayarlama çok küçüktü.\n\nKullanıcı ayarı: %1$@\nToplam sapma: %2$@\n\nİzlemeye devam edin ve ses seviyesi ölçerinizle karşılaştırın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Калібрування збережено. Коригування було дуже маленьким.\n\nКоригування користувача: %1$@\nЗагальне зміщення: %2$@\n\nПродовжуйте контролювати та порівнювати з шумоміром."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã lưu hiệu chuẩn. Sự điều chỉnh là rất nhỏ.\n\nNgười dùng điều chỉnh: %1$@\nTổng số tiền bù đắp: %2$@\n\nTiếp tục theo dõi và so sánh với máy đo mức âm thanh của bạn."
          }
        }
      }
    },
