    "dashboard.idle.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitoring is paused. Tap below to resume live measurement."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监测已暂停。点击下方按钮恢复实时监测。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "監測已暫停。點擊下方按鈕恢復即時監測。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إيقاف المراقبة مؤقتًا. انقر أدناه لاستئناف القياس المباشر."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Наблюдението е на пауза. Докоснете по-долу, за да възобновите измерването на живо."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El seguiment està en pausa. Toqueu a continuació per reprendre el mesurament en directe."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledování je pozastaveno. Klepnutím níže obnovíte živé měření."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Overvågning er sat på pause. Tryk nedenfor for at genoptage livemåling."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Überwachung ist pausiert. Tippen Sie unten, um die Live-Messung fortzusetzen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η παρακολούθηση έχει διακοπεί. Πατήστε παρακάτω για να συνεχίσετε τη ζωντανή μέτρηση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La monitorización está en pausa. Toque a continuación para reanudar la medición en vivo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valvonta on keskeytetty. Jatka suoraa mittausta napauttamalla alla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La surveillance est suspendue. Appuyez ci-dessous pour reprendre la mesure en direct."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הניטור מושהה. הקש למטה כדי לחדש את המדידה בזמן אמת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निगरानी रोक दी गई है. लाइव माप फिर से शुरू करने के लिए नीचे टैप करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Praćenje je pauzirano. Dodirnite ispod za nastavak mjerenja uživo."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A megfigyelés szünetel. Érintse meg lent az élő mérés folytatásához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemantauan dijeda. Ketuk di bawah untuk melanjutkan pengukuran langsung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il monitoraggio è in pausa. Tocca sotto per riprendere la misurazione dal vivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "監視は一時停止されています。ライブ測定を再開するには、下をタップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모니터링이 일시중지되었습니다. 실시간 측정을 재개하려면 아래를 탭하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemantauan dijeda. Ketik di bawah untuk menyambung semula pengukuran langsung."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Overvåking er satt på pause. Trykk nedenfor for å gjenoppta live-måling."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De bewaking is onderbroken. Tik hieronder om de live meting te hervatten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorowanie zostało wstrzymane. Kliknij poniżej, aby wznowić pomiar na żywo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O monitoramento está pausado. Toque abaixo para retomar a medição ao vivo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorizarea este întreruptă. Atingeți mai jos pentru a relua măsurarea live."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мониторинг приостановлен. Нажмите ниже, чтобы возобновить измерение в реальном времени."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorovanie je pozastavené. Klepnutím nižšie obnovíte živé meranie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Övervakningen är pausad. Tryck nedan för att återuppta livemätning."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การตรวจสอบถูกหยุดชั่วคราว แตะด้านล่างเพื่อดำเนินการวัดผลแบบเรียลไทม์ต่อ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İzleme duraklatıldı. Canlı ölçüme devam etmek için aşağıya dokunun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Моніторинг призупинено. Натисніть нижче, щоб відновити вимірювання в реальному часі."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giám sát bị tạm dừng. Nhấn vào bên dưới để tiếp tục đo trực tiếp."
          }
        }
      }
    },
